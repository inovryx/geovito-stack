---
import MainLayout from '../../../../layouts/MainLayout.astro';
import FollowUserPanel from '../../../../components/community/FollowUserPanel.astro';
import { SUPPORTED_LANGUAGES, pathForLanguage } from '../../../../lib/languages';
import { absoluteUrl, buildLanguageLinks, toAlternates } from '../../../../lib/pageHelpers';
import { getCreatorPostsByUsername, getCreatorProfiles } from '../../../../lib/strapi';
import { getUiMessages, translate } from '../../../../lib/uiLanguage';

export const prerender = true;

export async function getStaticPaths() {
  const profiles = await getCreatorProfiles();
  const usernames = Array.from(
    new Set(
      profiles
        .map((entry) => String(entry.username || '').trim().toLowerCase())
        .filter(Boolean)
    )
  );

  return usernames.map((username) => ({
    params: { username },
  }));
}

const username = String(Astro.params.username || '').trim().toLowerCase();
if (!username) {
  throw new Error('username is required.');
}

const ui = getUiMessages('en');
const payload = await getCreatorPostsByUsername(username, 'en');
if (!payload.profile) {
  throw new Error(`creator profile not found: ${username}`);
}

const profile = payload.profile;
const posts = Array.isArray(payload.posts) ? payload.posts : [];
const languageLinks = buildLanguageLinks(
  Object.fromEntries(
    SUPPORTED_LANGUAGES.map((lang) => [lang, pathForLanguage(lang, `@${username}/posts`)])
  ) as Record<string, string>
);
const alternates = toAlternates(languageLinks);
const canonical = absoluteUrl(pathForLanguage('en', `@${username}/posts`));
const t = (key: string, params: Record<string, string | number> = {}, fallback?: string) => translate(ui, key, params, fallback);
---

<MainLayout
  title={t('profile.meta.postsTitle', { username: `@${username}` }, '{username} posts • Geovito')}
  description={t('profile.meta.postsDescription', { username: `@${username}` }, 'Visible posts from {username}')}
  canonical={canonical}
  robots="noindex,nofollow"
  currentLanguage="en"
  languageLinks={languageLinks}
  alternates={alternates}
  ui={ui}
>
  <section class="card panel gv-card gv-stack">
    <p class="gv-caption">{t('profile.labels.creatorPosts', {}, 'Creator posts')}</p>
    <h1 class="gv-h1">{profile.display_name || `@${username}`}</h1>
    <nav class="gv-row gv-row--gap" aria-label={t('profile.navigation.aria', {}, 'Creator navigation')}>
      <a class="ui-button ui-button-secondary ui-button-sm" href={pathForLanguage('en', `@${username}`)}>{t('profile.navigation.home', {}, 'Home')}</a>
      <a class="ui-button ui-button-secondary ui-button-sm" href={pathForLanguage('en', `@${username}/posts`)}>{t('profile.navigation.posts', {}, 'Posts')}</a>
      <a class="ui-button ui-button-secondary ui-button-sm" href={pathForLanguage('en', `@${username}/about`)}>{t('profile.navigation.about', {}, 'About')}</a>
    </nav>
  </section>

  <FollowUserPanel username={username} lang="en" />

  <section class="card panel gv-card gv-stack">
    <h2 class="gv-h2">{t('profile.labels.visiblePosts', {}, 'Visible posts')}</h2>
    {
      posts.length > 0 ? (
        <ul class="gv-stack">
          {posts.map((post) => (
            <li class="card">
              <a href={String(post.url_path || '#')}>
                <strong>{String(post.title || post.post_id || t('profile.labels.untitledPost', {}, 'Untitled'))}</strong>
              </a>
              <p class="small">
                {String(post.excerpt || '')}
              </p>
              <p class="gv-caption">
                {String(post.language || 'en').toUpperCase()} • {String(post.published_on || '') || '—'}
                {
                  String(post.submission_state || '').toLowerCase() === 'submitted' ? (
                    <>
                      {' · '}
                      <span class="status-pill">{t('profile.labels.inReview', {}, 'In review')}</span>
                    </>
                  ) : null
                }
              </p>
            </li>
          ))}
        </ul>
      ) : (
        <p class="small">{t('profile.labels.noVisiblePosts', {}, 'No visible posts yet.')}</p>
      )
    }
  </section>
</MainLayout>
