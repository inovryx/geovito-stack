---
import MainLayout from '../../../../layouts/MainLayout.astro';
import FollowUserPanel from '../../../../components/community/FollowUserPanel.astro';
import { SUPPORTED_LANGUAGES, pathForLanguage } from '../../../../lib/languages';
import { absoluteUrl, buildLanguageLinks, toAlternates } from '../../../../lib/pageHelpers';
import { getCreatorProfileByUsername, getCreatorProfiles } from '../../../../lib/strapi';
import { getUiMessages, translate } from '../../../../lib/uiLanguage';

export const prerender = true;

export async function getStaticPaths() {
  const profiles = await getCreatorProfiles();
  const usernames = Array.from(
    new Set(
      profiles
        .map((entry) => String(entry.username || '').trim().toLowerCase())
        .filter(Boolean)
    )
  );

  return usernames.map((username) => ({
    params: { username },
  }));
}

const username = String(Astro.params.username || '').trim().toLowerCase();
if (!username) {
  throw new Error('username is required.');
}

const ui = getUiMessages('en');
const profile = await getCreatorProfileByUsername(username);
if (!profile) {
  throw new Error(`creator profile not found: ${username}`);
}

const languageLinks = buildLanguageLinks(
  Object.fromEntries(
    SUPPORTED_LANGUAGES.map((lang) => [lang, pathForLanguage(lang, `@${username}/about`)])
  ) as Record<string, string>
);
const alternates = toAlternates(languageLinks);
const canonical = absoluteUrl(pathForLanguage('en', `@${username}/about`));
const socialLinks = profile.social_links && typeof profile.social_links === 'object' ? profile.social_links : null;
const t = (key: string, params: Record<string, string | number> = {}, fallback?: string) => translate(ui, key, params, fallback);
---

<MainLayout
  title={t('profile.meta.aboutTitle', { username: `@${username}` }, 'About {username} • Geovito')}
  description={profile.bio || t('profile.meta.aboutDescription', { username: `@${username}` }, 'About {username}')}
  canonical={canonical}
  robots="noindex,nofollow"
  currentLanguage="en"
  languageLinks={languageLinks}
  alternates={alternates}
  ui={ui}
>
  <section class="card panel gv-card gv-stack">
    <p class="gv-caption">{t('profile.labels.creatorProfile', {}, 'Creator profile')}</p>
    <h1 class="gv-h1">{profile.display_name || `@${username}`}</h1>
    <p class="small">@{profile.username}</p>
    <nav class="gv-row gv-row--gap" aria-label={t('profile.navigation.aria', {}, 'Creator navigation')}>
      <a class="ui-button ui-button-secondary ui-button-sm" href={pathForLanguage('en', `@${username}`)}>{t('profile.navigation.home', {}, 'Home')}</a>
      <a class="ui-button ui-button-secondary ui-button-sm" href={pathForLanguage('en', `@${username}/posts`)}>{t('profile.navigation.posts', {}, 'Posts')}</a>
      <a class="ui-button ui-button-secondary ui-button-sm" href={pathForLanguage('en', `@${username}/about`)}>{t('profile.navigation.about', {}, 'About')}</a>
    </nav>
  </section>

  <FollowUserPanel username={username} lang="en" />

  <section class="card panel gv-card gv-stack">
    <h2 class="gv-h2">{t('profile.navigation.about', {}, 'About')}</h2>
    <p class="gv-body">{profile.bio || t('profile.labels.noBiography', {}, 'No biography provided yet.')}</p>
    <p class="small">{t('profile.labels.visibility', {}, 'Visibility')}: {String(profile.visibility || 'public')}</p>
  </section>

  <section class="card panel gv-card gv-stack">
    <h2 class="gv-h2">{t('profile.labels.citizenCardStatus', {}, 'Citizen card status')}</h2>
    <p class="small">{profile.citizen_card_enabled === false ? t('profile.status.disabled', {}, 'Disabled') : t('profile.status.enabled', {}, 'Enabled')}</p>
    <p class="small">{t('profile.stats.posts', {}, 'Posts')}: {Number(profile.stats?.posts_count || 0)}</p>
    <p class="small">{t('profile.stats.countries', {}, 'Countries')}: {Number(profile.stats?.countries_count || 0)}</p>
    <p class="small">{t('profile.stats.cities', {}, 'Cities')}: {Number(profile.stats?.cities_count || 0)}</p>
  </section>

  {
    socialLinks ? (
      <section class="card panel gv-card gv-stack">
        <h2 class="gv-h2">{t('profile.labels.socialLinks', {}, 'Social links')}</h2>
        <pre class="gv-caption">{JSON.stringify(socialLinks, null, 2)}</pre>
      </section>
    ) : null
  }
</MainLayout>
