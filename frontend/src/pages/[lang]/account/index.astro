      const commentsRefreshButton = document.querySelector('[data-account-comments-refresh]');
      const commentsFilterSelect = document.querySelector('[data-account-comments-filter]');
      const commentsCountPending = document.querySelector('[data-account-comments-pending]');
      const commentsCountApproved = document.querySelector('[data-account-comments-approved]');
      const commentsCountRejected = document.querySelector('[data-account-comments-rejected]');
      const commentsCountSpam = document.querySelector('[data-account-comments-spam]');
      const accountRequestsForm = document.querySelector('[data-account-requests-form]');
      const accountRequestsTypeSelect = document.querySelector('[data-account-request-type]');
      const accountRequestsReasonInput = document.querySelector('[data-account-request-reason]');
      const accountRequestsSubmitButton = document.querySelector('[data-account-requests-submit]');
      const accountRequestsFeedback = document.querySelector('[data-account-requests-feedback]');
      const accountRequestsList = document.querySelector('[data-account-requests-list]');
      const accountRequestsEmpty = document.querySelector('[data-account-requests-empty]');
      const accountRequestsRefreshButton = document.querySelector('[data-account-requests-refresh]');
      const accountRequestsFilterSelect = document.querySelector('[data-account-requests-filter]');
      const accountRequestsCountNew = document.querySelector('[data-account-requests-new]');
      const accountRequestsCountApproved = document.querySelector('[data-account-requests-approved]');
      const accountRequestsCountRejected = document.querySelector('[data-account-requests-rejected]');
      const accountRequestsCountCompleted = document.querySelector('[data-account-requests-completed]');
      const localeProgressList = document.querySelector('[data-account-locale-progress-list]');
      const localeProgressEmpty = document.querySelector('[data-account-locale-progress-empty]');
      const localeProgressFeedback = document.querySelector('[data-account-locale-progress-feedback]');
      const localeProgressRefreshButton = document.querySelector('[data-account-locale-progress-refresh]');
      const localeProgressFilterSelect = document.querySelector('[data-account-locale-progress-filter]');
      const localeProgressMissingLocales = document.querySelector('[data-account-locale-progress-missing-locales]');
      const localeProgressUntranslatedLocales = document.querySelector('[data-account-locale-progress-untranslated-locales]');
      const localeProgressDeployCount = document.querySelector('[data-account-locale-progress-deploy-count]');
      const localeProgressActiveFilter = document.querySelector('[data-account-locale-progress-active-filter]');
      const localeProgressFilteredTotal = document.querySelector('[data-account-locale-progress-filtered-total]');
      const localeDeployHint = document.querySelector('[data-account-locale-deploy-hint]');
      const localeDeployBody = document.querySelector('[data-account-locale-deploy-body]');
      const localeDeployCommand = document.querySelector('[data-account-locale-deploy-command]');
      const localeDeployCopyButton = document.querySelector('[data-account-locale-deploy-copy]');
      const localeReleaseCommand = document.querySelector('[data-account-locale-release-command]');
      const localeReleaseCopyButton = document.querySelector('[data-account-locale-release-copy]');
      const localeWorkflowCommand = document.querySelector('[data-account-locale-workflow-command]');
      const localeWorkflowCopyButton = document.querySelector('[data-account-locale-workflow-copy]');
      const localeDeployFeedback = document.querySelector('[data-account-locale-deploy-feedback]');
      const form = document.querySelector('[data-account-language-form]');
      const feedback = document.querySelector('[data-account-feedback]');
      const select = document.querySelector('[data-account-language-select]');
      const languageHealth = document.querySelector('[data-account-language-health]');
      const notificationsForm = document.querySelector('[data-account-notifications-form]');
      const notificationsSite = document.querySelector('[data-account-notifications-site]');
      const notificationsEmail = document.querySelector('[data-account-notifications-email]');
      const notificationsDigest = document.querySelector('[data-account-notifications-digest]');
      const notificationsFeedback = document.querySelector('[data-account-notifications-feedback]');
      const onboardingForm = document.querySelector('[data-account-onboarding-form]');
      const onboardingProfileCompleted = document.querySelector('[data-account-onboarding-profile-completed]');
      const onboardingFirstPlaceSelected = document.querySelector('[data-account-onboarding-first-place-selected]');
      const onboardingFirstPostStarted = document.querySelector('[data-account-onboarding-first-post-started]');
      const onboardingSharePromptSeen = document.querySelector('[data-account-onboarding-share-prompt-seen]');
      const onboardingSkipped = document.querySelector('[data-account-onboarding-skipped]');
      const onboardingStatus = document.querySelector('[data-account-onboarding-status]');
      const onboardingProgress = document.querySelector('[data-account-onboarding-progress]');
      const onboardingCompleted = document.querySelector('[data-account-onboarding-completed]');
      const onboardingFeedback = document.querySelector('[data-account-onboarding-feedback]');
      const passwordForm = document.querySelector('[data-account-password-form]');
      const passwordFeedback = document.querySelector('[data-account-password-feedback]');

      if (
        !(settingsPanel instanceof HTMLElement) ||
        !(passwordPanel instanceof HTMLElement) ||
        !(loggedOutPanel instanceof HTMLElement) ||
        !(profilePanel instanceof HTMLElement) ||
        !(commentsPanel instanceof HTMLElement) ||
        !(accountRequestsPanel instanceof HTMLElement) ||
        !(localeProgressPanel instanceof HTMLElement)
      ) {
        return;
      }
      if (
        !(form instanceof HTMLFormElement) ||
        !(feedback instanceof HTMLElement) ||
        !(select instanceof HTMLSelectElement) ||
        !(languageHealth instanceof HTMLElement)
      )
        return;
      if (
        !(notificationsForm instanceof HTMLFormElement) ||
        !(notificationsSite instanceof HTMLInputElement) ||
        !(notificationsEmail instanceof HTMLInputElement) ||
        !(notificationsDigest instanceof HTMLSelectElement) ||
        !(notificationsFeedback instanceof HTMLElement)
      )
        return;
      if (
        !(onboardingForm instanceof HTMLFormElement) ||
        !(onboardingProfileCompleted instanceof HTMLInputElement) ||
        !(onboardingFirstPlaceSelected instanceof HTMLInputElement) ||
        !(onboardingFirstPostStarted instanceof HTMLInputElement) ||
        !(onboardingSharePromptSeen instanceof HTMLInputElement) ||
        !(onboardingSkipped instanceof HTMLInputElement) ||
        !(onboardingStatus instanceof HTMLElement) ||
        !(onboardingProgress instanceof HTMLElement) ||
        !(onboardingCompleted instanceof HTMLElement) ||
        !(onboardingFeedback instanceof HTMLElement)
      )
        return;
      if (!(passwordForm instanceof HTMLFormElement) || !(passwordFeedback instanceof HTMLElement)) return;
      if (
        !(profileUsername instanceof HTMLElement) ||
        !(profileEmail instanceof HTMLElement) ||
        !(profileCreated instanceof HTMLElement) ||
        !(profileStatus instanceof HTMLElement) ||
        !(commentsList instanceof HTMLElement) ||
        !(commentsEmpty instanceof HTMLElement) ||
        !(commentsFeedback instanceof HTMLElement) ||
        !(commentsRefreshButton instanceof HTMLButtonElement) ||
        !(commentsFilterSelect instanceof HTMLSelectElement) ||
        !(commentsCountPending instanceof HTMLElement) ||
        !(commentsCountApproved instanceof HTMLElement) ||
        !(commentsCountRejected instanceof HTMLElement) ||
        !(commentsCountSpam instanceof HTMLElement) ||
        !(accountRequestsForm instanceof HTMLFormElement) ||
        !(accountRequestsTypeSelect instanceof HTMLSelectElement) ||
        !(accountRequestsReasonInput instanceof HTMLTextAreaElement) ||
        !(accountRequestsSubmitButton instanceof HTMLButtonElement) ||
        !(accountRequestsFeedback instanceof HTMLElement) ||
        !(accountRequestsList instanceof HTMLElement) ||
        !(accountRequestsEmpty instanceof HTMLElement) ||
        !(accountRequestsRefreshButton instanceof HTMLButtonElement) ||
        !(accountRequestsFilterSelect instanceof HTMLSelectElement) ||
        !(accountRequestsCountNew instanceof HTMLElement) ||
        !(accountRequestsCountApproved instanceof HTMLElement) ||
        !(accountRequestsCountRejected instanceof HTMLElement) ||
        !(accountRequestsCountCompleted instanceof HTMLElement) ||
        !(localeProgressList instanceof HTMLElement) ||
        !(localeProgressEmpty instanceof HTMLElement) ||
        !(localeProgressFeedback instanceof HTMLElement) ||
        !(localeProgressRefreshButton instanceof HTMLButtonElement) ||
        !(localeProgressFilterSelect instanceof HTMLSelectElement) ||
        !(localeProgressMissingLocales instanceof HTMLElement) ||
        !(localeProgressUntranslatedLocales instanceof HTMLElement) ||
        !(localeProgressDeployCount instanceof HTMLElement) ||
        !(localeProgressActiveFilter instanceof HTMLElement) ||
        !(localeProgressFilteredTotal instanceof HTMLElement) ||
        !(localeDeployHint instanceof HTMLElement) ||
        !(localeDeployBody instanceof HTMLElement) ||
        !(localeDeployCommand instanceof HTMLElement) ||
        !(localeDeployCopyButton instanceof HTMLButtonElement) ||
        !(localeReleaseCommand instanceof HTMLElement) ||
        !(localeReleaseCopyButton instanceof HTMLButtonElement) ||
        !(localeWorkflowCommand instanceof HTMLElement) ||
        !(localeWorkflowCopyButton instanceof HTMLButtonElement) ||
        !(localeDeployFeedback instanceof HTMLElement)
      ) {
        return;
      }

      const authBase = form.getAttribute('data-auth-base');
      if (!authBase) return;

      const normalizedLanguages = Array.isArray(availableLanguages) ? availableLanguages : [];
      const isAllowedLanguage = (value) => normalizedLanguages.includes(value);
      const normalizeLanguage = (value) => String(value || '').trim().toLowerCase();
      const normalizeNotificationDigest = (value) => {
        const normalized = String(value || '').trim().toLowerCase();
        if (normalized === 'off' || normalized === 'instant' || normalized === 'daily' || normalized === 'weekly') {
          return normalized;
        }
        return 'daily';
      };
      const normalizeOnboardingProgressData = (value) => {
        const source = value && typeof value === 'object' ? value : {};
        const normalized = {
          profile_completed: source.profile_completed === true,
          first_place_selected: source.first_place_selected === true,
          first_post_started: source.first_post_started === true,
          share_prompt_seen: source.share_prompt_seen === true,
          skipped: source.skipped === true,
        };
        const completedSteps = [
          normalized.profile_completed,
          normalized.first_place_selected,
          normalized.first_post_started,
          normalized.share_prompt_seen,
        ].filter(Boolean).length;
        const totalSteps = 4;
        const progressPercent = Math.round((completedSteps / totalSteps) * 100);
        const normalizedStatus = String(source.status || '').trim().toLowerCase();
        const status =
          normalizedStatus === 'completed' || normalizedStatus === 'skipped' || normalizedStatus === 'in_progress'
            ? normalizedStatus
            : normalized.skipped
              ? 'skipped'
              : completedSteps >= totalSteps
                ? 'completed'
                : 'in_progress';

        return {
          ...normalized,
          completed_steps: completedSteps,
          total_steps: totalSteps,
          progress_percent: Number.isFinite(Number(source.progress_percent))
            ? Math.max(0, Math.min(100, Math.round(Number(source.progress_percent))))
            : progressPercent,
          status,
        };
      };
      const normalizePreviewState = (value) => {
        const normalized = String(value || '').trim().toLowerCase();
        if (normalized === 'missing' || normalized === 'untranslated') return normalized;
        return 'all';
      };
      const normalizeCommentState = (value) => {
        const normalized = String(value || '').trim().toLowerCase();
        if (normalized === 'pending' || normalized === 'approved' || normalized === 'rejected' || normalized === 'spam') {
          return normalized;
        }
        return 'all';
      };
      const normalizeAccountRequestState = (value) => {
        const normalized = String(value || '').trim().toLowerCase();
        if (normalized === 'new' || normalized === 'approved' || normalized === 'rejected' || normalized === 'completed') {
          return normalized;
        }
        return 'all';
      };
      const queryParams = new URLSearchParams(window.location.search);
      const initialCommentState = normalizeCommentState(queryParams.get('commentState') || 'all');
      const initialRequestState = normalizeAccountRequestState(queryParams.get('requestState') || 'all');
      const initialLocaleFromQuery = normalizeLanguage(queryParams.get('locale') || '');
      const initialPreviewState = normalizePreviewState(queryParams.get('state') || 'all');
      let commentsAllItems = [];
      let accountRequestsAllItems = [];
      let commentsFocusPending = initialCommentState !== 'all' || window.location.hash === '#comments';
      let localeProgressFocusLocale = initialLocaleFromQuery;
      let localeProgressFocusPending = Boolean(initialLocaleFromQuery);
      const getCurrentCommentState = () => normalizeCommentState(commentsFilterSelect.value);
      const getCurrentPreviewState = () => normalizePreviewState(localeProgressFilterSelect.value);
      const getPreviewCacheKey = (localeCode, state) => `${normalizeLanguage(localeCode)}:${normalizePreviewState(state)}`;
      const localeProgressByLocale = new Map();
      const localePreviewCache = new Map();
      const deployCommandText = String(accountCopy.localeProgressDeployCommand || 'bash tools/ui_locale_sync.sh');
      const releaseCommandText = String(
        accountCopy.localeProgressDeployReleaseCommand || 'bash tools/release_deploy_smoke.sh --with-moderation'
      );
      const workflowCommandText = String(
        accountCopy.localeProgressDeployWorkflowCommand ||
          'bash tools/ui_locale_sync.sh && EXPECTED_SHA7=$(git rev-parse --short=7 HEAD) bash tools/release_deploy_smoke.sh --with-moderation'
      );
      localeDeployCommand.textContent = deployCommandText;
      localeReleaseCommand.textContent = releaseCommandText;
      localeWorkflowCommand.textContent = workflowCommandText;

      const getPreviewStateLabel = (state) => {
        const normalized = normalizePreviewState(state);
        if (normalized === 'missing') return accountCopy.localeProgressFilterMissing;
        if (normalized === 'untranslated') return accountCopy.localeProgressFilterUntranslated;
        return accountCopy.localeProgressFilterAll;
      };

      const setFeedback = (message, isError = false) => {
        feedback.textContent = message;
        feedback.classList.toggle('is-error', isError);
      };

      const setNotificationsFeedback = (message, isError = false) => {
        notificationsFeedback.textContent = message;
        notificationsFeedback.classList.toggle('is-error', isError);
      };

      const setOnboardingFeedback = (message, isError = false) => {
        onboardingFeedback.textContent = message;
        onboardingFeedback.classList.toggle('is-error', isError);
      };

      const setProfileFeedback = (message, isError = false) => {
        if (!(profileFeedback instanceof HTMLElement)) return;
        profileFeedback.textContent = message;
        profileFeedback.classList.toggle('is-error', isError);
      };

      const setPasswordFeedback = (message, isError = false) => {
        passwordFeedback.textContent = message;
        passwordFeedback.classList.toggle('is-error', isError);
      };

      const setCommentsFeedback = (message, isError = false) => {
        commentsFeedback.textContent = message;
        commentsFeedback.classList.toggle('is-error', isError);
      };

      const setAccountRequestsFeedback = (message, isError = false) => {
        accountRequestsFeedback.textContent = message;
        accountRequestsFeedback.classList.toggle('is-error', isError);
      };

      const setLocaleProgressFeedback = (message, isError = false) => {
        localeProgressFeedback.textContent = message;
        localeProgressFeedback.classList.toggle('is-error', isError);
      };

      const setLocaleDeployFeedback = (message, isError = false) => {
        localeDeployFeedback.textContent = message;
        localeDeployFeedback.classList.toggle('is-error', isError);
      };

      const setCommentsCounts = (meta) => {
        const counts = meta && typeof meta === 'object' ? meta.counts || {} : {};
        commentsCountPending.textContent = String(Number(counts.pending) || 0);
        commentsCountApproved.textContent = String(Number(counts.approved) || 0);
        commentsCountRejected.textContent = String(Number(counts.rejected) || 0);
        commentsCountSpam.textContent = String(Number(counts.spam) || 0);
      };

      const setAccountRequestsCounts = (items) => {
        const list = Array.isArray(items) ? items : [];
        let newCount = 0;
        let approvedCount = 0;
        let rejectedCount = 0;
        let completedCount = 0;

        for (const item of list) {
          const status = normalizeAccountRequestState(item?.status);
          if (status === 'new') newCount += 1;
          if (status === 'approved') approvedCount += 1;
          if (status === 'rejected') rejectedCount += 1;
          if (status === 'completed') completedCount += 1;
        }

        accountRequestsCountNew.textContent = String(newCount);
        accountRequestsCountApproved.textContent = String(approvedCount);
        accountRequestsCountRejected.textContent = String(rejectedCount);
        accountRequestsCountCompleted.textContent = String(completedCount);
      };

      const setLocaleProgressSummary = (summary) => {
        const source = summary && typeof summary === 'object' ? summary : {};
        localeProgressMissingLocales.textContent = String(Number(source.locales_with_missing) || 0);
        localeProgressUntranslatedLocales.textContent = String(Number(source.locales_with_untranslated) || 0);
        localeProgressDeployCount.textContent = String(Number(source.deploy_required_count) || 0);
      };

      const setLocaleDeployHint = (summary) => {
        const source = summary && typeof summary === 'object' ? summary : {};
        const deployRequiredCount = Number(source.deploy_required_count) || 0;
        localeDeployHint.hidden = deployRequiredCount <= 0;
        if (deployRequiredCount <= 0) {
          setLocaleDeployFeedback('');
          return;
        }

        localeDeployBody.textContent = String(accountCopy.localeProgressDeployActionBody || '').replace(
          '{count}',
          String(deployRequiredCount)
        );
      };

      const setLocaleFilterSummary = () => {
        const state = getCurrentPreviewState();
        localeProgressActiveFilter.textContent = getPreviewStateLabel(state);
        let total = 0;
        for (const row of localeProgressByLocale.values()) {
          const missing = Number(row?.missing_keys || 0);
          const untranslated = Number(row?.untranslated_keys || 0);
          if (state === 'missing') {
            total += missing;
            continue;
          }
          if (state === 'untranslated') {
            total += untranslated;
            continue;
          }
          total += missing + untranslated;
        }
        localeProgressFilteredTotal.textContent = String(total);
      };

      const getLocaleWorkCount = (localeCode) => {
        const normalized = normalizeLanguage(localeCode);
        if (!normalized || !localeProgressByLocale.has(normalized)) return null;
        const row = localeProgressByLocale.get(normalized);
        const missing = Number(row?.missing_keys || 0);
        const untranslated = Number(row?.untranslated_keys || 0);
        return missing + untranslated;
      };

      const updateSelectOptionLabels = () => {
        const options = Array.from(select.options);
        for (const option of options) {
          const localeCode = normalizeLanguage(option.value);
          const defaultLabel = option.dataset.defaultLabel || option.value.toUpperCase();
          const workCount = getLocaleWorkCount(localeCode);
          if (workCount === null) {
            option.textContent = defaultLabel;
            continue;
          }
          option.textContent = workCount > 0 ? `${defaultLabel} · ${workCount}` : defaultLabel;
        }
      };

      const updateLanguageHealth = () => {
        const selectedLocale = normalizeLanguage(select.value);
        if (!selectedLocale || !isAllowedLanguage(selectedLocale)) {
          languageHealth.textContent = '';
          languageHealth.classList.remove('is-error');
          return;
        }

        const workCount = getLocaleWorkCount(selectedLocale);
        if (workCount === null) {
          languageHealth.textContent = accountCopy.languageHealthUnknown;
          languageHealth.classList.add('is-error');
          return;
        }

        if (workCount > 0) {
          languageHealth.textContent = String(accountCopy.languageHealthWarning || '').replace('{count}', String(workCount));
          languageHealth.classList.add('is-error');
          return;
        }

        languageHealth.textContent = accountCopy.languageHealthComplete;
        languageHealth.classList.remove('is-error');
      };

      const escapeHtml = (value) =>
        String(value || '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');

      const formatPreviewValue = (value) => {
        if (value === null || value === undefined) return '∅';
        const text = String(value);
        return text.length > 120 ? `${text.slice(0, 117)}...` : text;
      };

      const csvEscape = (value) => `"${String(value ?? '').replaceAll('"', '""')}"`;

      const rowsToCsv = (rows) => {
        const list = Array.isArray(rows) ? rows : [];
        const lines = ['key,state,reference_value,locale_value'];
        for (const row of list) {
          lines.push(
            [
              csvEscape(row?.key || ''),
              csvEscape(row?.state || ''),
              csvEscape(row?.reference_value ?? ''),
              csvEscape(row?.locale_value ?? ''),
            ].join(',')
          );
        }
        return `${lines.join('\n')}\n`;
      };

      const findLocalePreviewNode = (localeCode) => {
        const normalized = normalizeLanguage(localeCode);
        if (!normalized) return null;
        const nodes = localeProgressList.querySelectorAll('[data-account-locale-preview]');
        for (const node of nodes) {
          if (!(node instanceof HTMLElement)) continue;
          const current = normalizeLanguage(node.getAttribute('data-account-locale-preview'));
          if (current === normalized) {
            return node;
          }
        }
        return null;
      };

      const findLocaleItemNode = (localeCode) => {
        const normalized = normalizeLanguage(localeCode);
        if (!normalized) return null;
        const nodes = localeProgressList.querySelectorAll('[data-account-locale-item]');
        for (const node of nodes) {
          if (!(node instanceof HTMLElement)) continue;
          const current = normalizeLanguage(node.getAttribute('data-account-locale-item'));
          if (current === normalized) {
            return node;
          }
        }
        return null;
      };

      const fetchLocalePreviewRows = async (localeCode, state = 'all', limit = 12) => {
        const normalized = normalizeLanguage(localeCode);
        const normalizedState = normalizePreviewState(state);
        if (!normalized) return [];
        const response = await fetch(
          `${authBase}/api/ui-locales/meta/${encodeURIComponent(normalized)}/reference-preview?reference_locale=en&state=${encodeURIComponent(normalizedState)}&limit=${limit}`,
          {
            headers: {
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
          }
        );
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(String(payload?.error?.message || accountCopy.localeProgressLoadFailed));
        }
        const rows = Array.isArray(payload?.data?.rows) ? payload.data.rows : [];
        if (normalizedState === 'all') {
          return rows.filter((item) => item?.state === 'missing' || item?.state === 'untranslated');
        }
        return rows.filter((item) => item?.state === normalizedState);
      };

      const clearAuthSession = () => {
        try {
          localStorage.removeItem('geovito_auth_session');
          sessionStorage.removeItem('geovito_auth_session');
        } catch {
          // no-op
        }
      };

      const formatDate = (value) => {
        if (!value) return accountCopy.profileUnknown;
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return accountCopy.profileUnknown;
        try {
          return new Intl.DateTimeFormat(document.documentElement.lang || 'en', {
            dateStyle: 'medium',
            timeStyle: 'short',
          }).format(date);
        } catch {
          return date.toISOString();
        }
      };

      const renderProfile = (payload) => {
        const username = String(payload?.username || '').trim();
        const email = String(payload?.email || '').trim();
        const createdAt = payload?.createdAt || payload?.loginAt;
        const blocked = payload?.blocked === true;
        const confirmed = payload?.confirmed !== false;

        profileUsername.textContent = username || accountCopy.profileUnknown;
        profileEmail.textContent = email || accountCopy.profileUnknown;
        profileCreated.textContent = formatDate(createdAt);

        if (blocked) {
          profileStatus.textContent = accountCopy.profileStatusBlocked;
        } else if (!confirmed) {
          profileStatus.textContent = accountCopy.profileStatusPending;
        } else {
          profileStatus.textContent = accountCopy.profileStatusActive;
        }
      };

      const readSession = () => {
        try {
          const readRaw = () => {
            const fromLocal = localStorage.getItem('geovito_auth_session');
            if (fromLocal) return fromLocal;
            const fromSession = sessionStorage.getItem('geovito_auth_session');
            if (fromSession) {
              localStorage.setItem('geovito_auth_session', fromSession);
            }
            return fromSession;
          };

          const raw = readRaw();
          if (!raw) return null;
          const parsed = JSON.parse(raw);
          if (!parsed || typeof parsed !== 'object') return null;
          if (!parsed.jwt || typeof parsed.jwt !== 'string') return null;
          return parsed;
        } catch {
          return null;
        }
      };

      const session = readSession();
      if (!session) {
        settingsPanel.hidden = true;
        passwordPanel.hidden = true;
        profilePanel.hidden = true;
        commentsPanel.hidden = true;
        accountRequestsPanel.hidden = true;
        localeProgressPanel.hidden = true;
        loggedOutPanel.hidden = false;
        return;
      }

      settingsPanel.hidden = false;
      passwordPanel.hidden = false;
      profilePanel.hidden = false;
      commentsPanel.hidden = false;
      accountRequestsPanel.hidden = false;
      localeProgressPanel.hidden = false;
      loggedOutPanel.hidden = true;
      renderProfile(session);
      notificationsSite.checked = true;
      notificationsEmail.checked = true;
      notificationsDigest.value = 'daily';

      const applyPreferredLanguage = (language) => {
        const normalized = normalizeLanguage(language);
        if (!isAllowedLanguage(normalized)) return false;
        select.value = normalized;
        updateLanguageHealth();
        try {
          localStorage.setItem('geovito.ui_lang', normalized);
        } catch {
          // no-op
        }
        return true;
      };

      const applyNotificationPreference = (data) => {
        const source = data && typeof data === 'object' ? data : {};
        notificationsSite.checked = source.notifications_site_enabled !== false;
        notificationsEmail.checked = source.notifications_email_enabled !== false;
        notificationsDigest.value = normalizeNotificationDigest(source.notifications_digest);
      };

      const getOnboardingStatusLabel = (status) => {
        if (status === 'completed') return accountCopy.onboardingStatusCompleted;
        if (status === 'skipped') return accountCopy.onboardingStatusSkipped;
        return accountCopy.onboardingStatusInProgress;
      };

      const applyOnboardingPreference = (data) => {
        const source = data && typeof data === 'object' ? data : {};
        const normalized = normalizeOnboardingProgressData(source.onboarding_progress);

        onboardingProfileCompleted.checked = normalized.profile_completed;
        onboardingFirstPlaceSelected.checked = normalized.first_place_selected;
        onboardingFirstPostStarted.checked = normalized.first_post_started;
        onboardingSharePromptSeen.checked = normalized.share_prompt_seen;
        onboardingSkipped.checked = normalized.skipped;
        onboardingStatus.textContent = getOnboardingStatusLabel(normalized.status);
        onboardingProgress.textContent = `${normalized.progress_percent}%`;
        onboardingCompleted.textContent = String(accountCopy.onboardingStateSummary || '{completed}/{total} steps')
          .replace('{completed}', String(normalized.completed_steps))
          .replace('{total}', String(normalized.total_steps));
      };
      applyOnboardingPreference(null);

      const loadPreference = async () => {
        const localPreferred = normalizeLanguage(localStorage.getItem('geovito.ui_lang') || '');
        if (isAllowedLanguage(localPreferred)) {
          select.value = localPreferred;
          updateLanguageHealth();
        }

        try {
          const response = await fetch(`${authBase}/api/user-preferences/me`, {
            headers: {
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
          });
          if (!response.ok) return;
          const payload = await response.json().catch(() => null);
          const preferenceData = payload?.data && typeof payload.data === 'object' ? payload.data : {};
          const language = normalizeLanguage(preferenceData?.preferred_ui_language);
          if (applyPreferredLanguage(language)) {
            setFeedback(accountCopy.loadedPreference);
          }
          applyNotificationPreference(preferenceData);
          applyOnboardingPreference(preferenceData);
          setNotificationsFeedback(accountCopy.notificationsLoaded);
          setOnboardingFeedback(accountCopy.onboardingLoaded);
        } catch {
          // no-op
        }
      };

      const loadProfile = async () => {
        try {
          const response = await fetch(`${authBase}/api/users/me`, {
            headers: {
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
          });
          if (!response.ok) {
            setProfileFeedback(accountCopy.profileSyncFallback, true);
            return;
          }
          const payload = await response.json().catch(() => null);
          if (!payload || typeof payload !== 'object') {
            setProfileFeedback(accountCopy.profileSyncFallback, true);
            return;
          }
          renderProfile(payload);
          setProfileFeedback('');
        } catch {
          setProfileFeedback(accountCopy.profileSyncFallback, true);
        }
      };

      const renderComments = (items) => {
        commentsList.innerHTML = '';
        const list = Array.isArray(items) ? items : [];
        commentsEmpty.hidden = list.length > 0;
        if (list.length === 0) return;

        const fragment = document.createDocumentFragment();
        for (const item of list) {
          const li = document.createElement('li');
          li.className = 'account-comment-item';
          const postRef = escapeHtml(item?.blog_post_ref || '-');
          const status = escapeHtml(item?.status || '-');
          const note = escapeHtml(item?.moderation_notes || '');
          const body = escapeHtml(item?.body || '');
          const created = formatDate(item?.created_at);

          li.innerHTML = `
            <p class="account-comment-meta">
              <strong>${escapeHtml(accountCopy.commentsPostRef)}:</strong> ${postRef}
              · <strong>${escapeHtml(accountCopy.commentsStatus)}:</strong> ${status}
              · <span>${escapeHtml(created)}</span>
            </p>
            <p class="account-comment-body">${body}</p>
            ${note ? `<p class="account-comment-note"><strong>${escapeHtml(accountCopy.commentsModerationNote)}:</strong> ${note}</p>` : ''}
          `;
          fragment.appendChild(li);
        }
        commentsList.appendChild(fragment);
      };

      const applyCommentsFilter = (items) => {
        const state = getCurrentCommentState();
        const list = Array.isArray(items) ? items : [];
        if (state === 'all') return list;
        return list.filter((item) => normalizeCommentState(item?.status) === state);
      };

      const renderCommentsForCurrentFilter = () => {
        const filtered = applyCommentsFilter(commentsAllItems);
        renderComments(filtered);
        if (filtered.length === 0 && commentsAllItems.length > 0 && getCurrentCommentState() !== 'all') {
          setCommentsFeedback(accountCopy.commentsFilterEmpty);
          return;
        }
        setCommentsFeedback('');
      };

      const renderAccountRequests = (items) => {
        accountRequestsList.innerHTML = '';
        const list = Array.isArray(items) ? items : [];
        accountRequestsEmpty.hidden = list.length > 0;
        if (list.length === 0) return;

        const fragment = document.createDocumentFragment();
        for (const item of list) {
          const li = document.createElement('li');
          li.className = 'account-comment-item';
          const requestId = escapeHtml(item?.request_id || '-');
          const requestType = escapeHtml(item?.request_type || '-');
          const status = escapeHtml(item?.status || '-');
          const reason = escapeHtml(item?.reason || '');
          const resolution = escapeHtml(item?.resolution_note || '');
          const created = formatDate(item?.created_at);
          const resolved = formatDate(item?.resolved_at);

          li.innerHTML = `
            <p class="account-comment-meta">
              <strong>${escapeHtml(accountCopy.accountRequestsId)}:</strong> ${requestId}
              · <strong>${escapeHtml(accountCopy.accountRequestsType)}:</strong> ${requestType}
              · <strong>${escapeHtml(accountCopy.commentsStatus)}:</strong> ${status}
              · <span>${escapeHtml(created)}</span>
            </p>
            ${reason ? `<p class="account-comment-body"><strong>${escapeHtml(accountCopy.accountRequestsReason)}:</strong> ${reason}</p>` : ''}
            ${resolution ? `<p class="account-comment-note"><strong>${escapeHtml(accountCopy.accountRequestsResolution)}:</strong> ${resolution}</p>` : ''}
            ${item?.resolved_at ? `<p class="account-comment-meta">${escapeHtml(resolved)}</p>` : ''}
          `;
          fragment.appendChild(li);
        }

        accountRequestsList.appendChild(fragment);
      };

      const applyAccountRequestsFilter = (items) => {
        const state = normalizeAccountRequestState(accountRequestsFilterSelect.value);
        const list = Array.isArray(items) ? items : [];
        if (state === 'all') return list;
        return list.filter((item) => normalizeAccountRequestState(item?.status) === state);
      };

      const renderAccountRequestsForCurrentFilter = () => {
        const filtered = applyAccountRequestsFilter(accountRequestsAllItems);
        renderAccountRequests(filtered);
        if (filtered.length === 0 && accountRequestsAllItems.length > 0 && normalizeAccountRequestState(accountRequestsFilterSelect.value) !== 'all') {
          setAccountRequestsFeedback(accountCopy.accountRequestsFilterEmpty);
          return;
        }
        setAccountRequestsFeedback('');
      };

      const applyCommentsFocus = () => {
        if (!commentsFocusPending) return;
        commentsPanel.classList.add('account-comments-focus');
        commentsPanel.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        commentsFocusPending = false;
      };

      const loadComments = async () => {
        setCommentsFeedback(accountCopy.commentsLoading);
        try {
          const response = await fetch(`${authBase}/api/blog-comments/me/list?limit=30`, {
            headers: {
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || accountCopy.commentsLoadFailed;
            commentsAllItems = [];
            renderCommentsForCurrentFilter();
            setCommentsCounts(null);
            setCommentsFeedback(message, true);
            return;
          }

          const items = Array.isArray(payload?.data) ? payload.data : [];
          commentsAllItems = items;
          renderCommentsForCurrentFilter();
          setCommentsCounts(payload?.meta);
          applyCommentsFocus();
        } catch {
          commentsAllItems = [];
          renderCommentsForCurrentFilter();
          setCommentsCounts(null);
          setCommentsFeedback(accountCopy.commentsLoadFailed, true);
        }
      };

      const loadAccountRequests = async () => {
        setAccountRequestsFeedback(accountCopy.accountRequestsLoading);
        try {
          const response = await fetch(`${authBase}/api/account-requests/me/list?limit=60`, {
            headers: {
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
          });
          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || accountCopy.accountRequestsLoadFailed;
            accountRequestsAllItems = [];
            renderAccountRequestsForCurrentFilter();
            setAccountRequestsCounts([]);
            setAccountRequestsFeedback(message, true);
            return;
          }

          const items = Array.isArray(payload?.data) ? payload.data : [];
          accountRequestsAllItems = items;
          setAccountRequestsCounts(items);
          renderAccountRequestsForCurrentFilter();
          setAccountRequestsFeedback('');
        } catch {
          accountRequestsAllItems = [];
          renderAccountRequestsForCurrentFilter();
          setAccountRequestsCounts([]);
          setAccountRequestsFeedback(accountCopy.accountRequestsLoadFailed, true);
        }
      };

      const submitAccountRequest = async () => {
        const requestType = String(accountRequestsTypeSelect.value || '').trim().toLowerCase();
        const reason = String(accountRequestsReasonInput.value || '').trim();
        if (requestType !== 'deactivate' && requestType !== 'delete') {
          setAccountRequestsFeedback(accountCopy.accountRequestsSubmitFailed, true);
          return;
        }

        accountRequestsSubmitButton.disabled = true;
        setAccountRequestsFeedback(accountCopy.accountRequestsSubmitSaving);
        try {
          const response = await fetch(`${authBase}/api/account-requests/me/submit`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
            body: JSON.stringify({
              request_type: requestType,
              reason,
            }),
          });
          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || accountCopy.accountRequestsSubmitFailed;
            setAccountRequestsFeedback(message, true);
            return;
          }

          accountRequestsReasonInput.value = '';
          setAccountRequestsFeedback(accountCopy.accountRequestsSubmitSuccess);
          await loadAccountRequests();
        } catch {
          setAccountRequestsFeedback(accountCopy.accountRequestsSubmitFailed, true);
        } finally {
          accountRequestsSubmitButton.disabled = false;
        }
      };

      const renderLocaleProgress = (rows, referenceLocale) => {
        localeProgressList.innerHTML = '';
        const list = Array.isArray(rows) ? rows : [];
        localeProgressEmpty.hidden = list.length > 0;
        if (list.length === 0) return;

        const fragment = document.createDocumentFragment();
        const normalizedReference = normalizeLanguage(referenceLocale || 'en');
        const sorted = [...list].sort((left, right) => {
          const leftScore = Number(left?.missing_keys || 0) + Number(left?.untranslated_keys || 0);
          const rightScore = Number(right?.missing_keys || 0) + Number(right?.untranslated_keys || 0);
          if (rightScore !== leftScore) return rightScore - leftScore;
          return String(left?.ui_locale || '').localeCompare(String(right?.ui_locale || ''));
        });

        for (const item of sorted) {
          const locale = normalizeLanguage(item?.ui_locale || '-');
          const missing = Number(item?.missing_keys || 0);
          const untranslated = Number(item?.untranslated_keys || 0);
          const coverage = Number(item?.coverage_percent || 0);
          const deployRequired = item?.deploy_required === true;
          const status = String(item?.status || 'draft');

          const li = document.createElement('li');
          li.className = 'account-comment-item';
          li.setAttribute('data-account-locale-item', locale);
          if (missing > 0 || untranslated > 0) {
            li.classList.add('account-locale-item-needs-work');
          }

          li.innerHTML = `
            <p class="account-comment-meta">
              <strong>${escapeHtml(locale.toUpperCase() || '-')}</strong>
              · <strong>${escapeHtml(accountCopy.commentsStatus)}:</strong> ${escapeHtml(status)}
              ${locale === normalizedReference ? `· <strong>${escapeHtml(accountCopy.localeProgressReference)}</strong>` : ''}
            </p>
            <p class="account-comment-meta">
              <strong>${escapeHtml(accountCopy.localeProgressMissing)}:</strong> ${missing}
              · <strong>${escapeHtml(accountCopy.localeProgressUntranslated)}:</strong> ${untranslated}
              · <strong>${escapeHtml(accountCopy.localeProgressCoverage)}:</strong> ${Number.isFinite(coverage) ? coverage.toFixed(1) : '0.0'}%
            </p>
            ${deployRequired ? `<p class="account-comment-note"><strong>${escapeHtml(accountCopy.localeProgressDeployRequired)}</strong></p>` : ''}
            ${
              missing > 0 || untranslated > 0
                ? `
                  <div class="account-locale-actions">
                    <button
                      type="button"
                      class="ui-button ui-button-secondary ui-button-sm account-locale-preview-toggle"
                      data-account-locale-preview-toggle
                      data-locale-code="${escapeHtml(locale)}"
                      aria-expanded="false"
                    >
                      <span class="ui-button-label">${escapeHtml(accountCopy.localeProgressShowDetails)}</span>
                    </button>
                    <button
                      type="button"
                      class="ui-button ui-button-secondary ui-button-sm account-locale-preview-export"
                      data-account-locale-preview-export
                      data-locale-code="${escapeHtml(locale)}"
                    >
                      <span class="ui-button-label">${escapeHtml(accountCopy.localeProgressExportCsv)}</span>
                    </button>
                  </div>
                  <div class="account-locale-preview" data-account-locale-preview="${escapeHtml(locale)}" hidden></div>
                `
                : ''
            }
          `;
          fragment.appendChild(li);
        }

        localeProgressList.appendChild(fragment);
      };

      const applyLocaleProgressFocus = () => {
        const targetLocale = normalizeLanguage(localeProgressFocusLocale);
        if (!targetLocale) {
          localeProgressFocusPending = false;
          return;
        }

        const nodes = localeProgressList.querySelectorAll('[data-account-locale-item]');
        for (const node of nodes) {
          if (node instanceof HTMLElement) {
            node.classList.remove('account-locale-item-focus');
          }
        }

        const targetNode = findLocaleItemNode(targetLocale);
        if (!(targetNode instanceof HTMLElement)) {
          localeProgressFocusPending = false;
          return;
        }

        targetNode.classList.add('account-locale-item-focus');
        targetNode.scrollIntoView({ block: 'nearest', behavior: 'smooth' });

        const toggleButton = targetNode.querySelector('[data-account-locale-preview-toggle]');
        const previewNode = findLocalePreviewNode(targetLocale);
        if (
          localeProgressFocusPending &&
          toggleButton instanceof HTMLButtonElement &&
          previewNode instanceof HTMLElement &&
          previewNode.hidden
        ) {
          loadLocalePreview(targetLocale, previewNode, toggleButton);
        }

        localeProgressFocusPending = false;
      };

      const renderLocalePreview = (previewNode, rows) => {
        if (!(previewNode instanceof HTMLElement)) return;
        const list = Array.isArray(rows) ? rows.slice(0, 8) : [];
        if (list.length === 0) {
          previewNode.innerHTML = `<p class="account-comment-meta">${escapeHtml(accountCopy.localeProgressDetailsEmpty)}</p>`;
          return;
        }

        const items = list
          .map((row) => {
            const key = escapeHtml(row?.key || '-');
            const state = escapeHtml(row?.state || '-');
            const reference = escapeHtml(formatPreviewValue(row?.reference_value));
            const localeValue = escapeHtml(formatPreviewValue(row?.locale_value));
            return `
              <li class="account-locale-preview-item">
                <p class="account-comment-meta">
                  <strong>${escapeHtml(accountCopy.localeProgressDetailsKey)}:</strong> ${key}
                  · <strong>${escapeHtml(accountCopy.localeProgressDetailsState)}:</strong> ${state}
                </p>
                <p class="account-comment-meta"><strong>${escapeHtml(accountCopy.localeProgressDetailsRef)}:</strong> ${reference}</p>
                <p class="account-comment-meta"><strong>${escapeHtml(accountCopy.localeProgressDetailsLocale)}:</strong> ${localeValue}</p>
              </li>
            `;
          })
          .join('');

        previewNode.innerHTML = `<ul class="account-locale-preview-list">${items}</ul>`;
      };

      const loadLocalePreview = async (localeCode, previewNode, toggleButton) => {
        const normalized = normalizeLanguage(localeCode);
        const selectedState = getCurrentPreviewState();
        const cacheKey = getPreviewCacheKey(normalized, selectedState);
        if (!normalized || !(previewNode instanceof HTMLElement) || !(toggleButton instanceof HTMLButtonElement)) return;

        if (localePreviewCache.has(cacheKey)) {
          renderLocalePreview(previewNode, localePreviewCache.get(cacheKey));
          previewNode.hidden = false;
          toggleButton.setAttribute('aria-expanded', 'true');
          toggleButton.querySelector('.ui-button-label')?.replaceChildren(accountCopy.localeProgressHideDetails);
          return;
        }

        previewNode.hidden = false;
        previewNode.innerHTML = `<p class="account-comment-meta">${escapeHtml(accountCopy.localeProgressLoadingDetails)}</p>`;
        toggleButton.disabled = true;
        toggleButton.setAttribute('aria-expanded', 'true');

        try {
          const rows = await fetchLocalePreviewRows(normalized, selectedState, 12);
          localePreviewCache.set(cacheKey, rows);
          renderLocalePreview(previewNode, rows);
          toggleButton.querySelector('.ui-button-label')?.replaceChildren(accountCopy.localeProgressHideDetails);
        } catch {
          previewNode.innerHTML = `<p class="account-comment-meta is-error">${escapeHtml(accountCopy.localeProgressLoadFailed)}</p>`;
          toggleButton.querySelector('.ui-button-label')?.replaceChildren(accountCopy.localeProgressShowDetails);
        } finally {
          toggleButton.disabled = false;
        }
      };

      const exportLocalePreviewCsv = async (localeCode, exportButton) => {
        const normalized = normalizeLanguage(localeCode);
        const selectedState = getCurrentPreviewState();
        const cacheKey = getPreviewCacheKey(normalized, selectedState);
        if (!normalized || !(exportButton instanceof HTMLButtonElement)) return;

        exportButton.disabled = true;
        setLocaleProgressFeedback(accountCopy.localeProgressLoadingDetails);
        try {
          const rows = await fetchLocalePreviewRows(normalized, selectedState, 300);
          if (rows.length === 0) {
            setLocaleProgressFeedback(accountCopy.localeProgressExportEmpty);
            return;
          }

          const csv = rowsToCsv(rows);
          const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
          const objectUrl = URL.createObjectURL(blob);
          const downloadLink = document.createElement('a');
          downloadLink.href = objectUrl;
          downloadLink.download = `ui-locale-${normalized}-${selectedState}.csv`;
          downloadLink.rel = 'noopener';
          document.body.appendChild(downloadLink);
          downloadLink.click();
          downloadLink.remove();
          window.setTimeout(() => URL.revokeObjectURL(objectUrl), 0);

          localePreviewCache.set(cacheKey, rows);
          setLocaleProgressFeedback(
            String(accountCopy.localeProgressExportDone || '').replace('{locale}', normalized.toUpperCase())
          );
        } catch (error) {
          const message = error instanceof Error && error.message ? error.message : accountCopy.localeProgressExportFailed;
          setLocaleProgressFeedback(message, true);
        } finally {
          exportButton.disabled = false;
        }
      };

      const loadLocaleProgress = async () => {
        setLocaleProgressFeedback(accountCopy.localeProgressLoading);
        try {
          const response = await fetch(`${authBase}/api/ui-locales/meta/progress?reference_locale=en`, {
            headers: {
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || accountCopy.localeProgressLoadFailed;
            localeProgressByLocale.clear();
            localePreviewCache.clear();
            renderLocaleProgress([], 'en');
            setLocaleProgressSummary(null);
            setLocaleDeployHint(null);
            setLocaleFilterSummary();
            updateSelectOptionLabels();
            updateLanguageHealth();
            setLocaleProgressFeedback(message, true);
            return;
          }

          const data = payload?.data && typeof payload.data === 'object' ? payload.data : {};
          const rows = Array.isArray(data.locales) ? data.locales : [];
          const summary = data.summary && typeof data.summary === 'object' ? data.summary : {};
          const referenceLocale = normalizeLanguage(summary.reference_locale || 'en');

          localeProgressByLocale.clear();
          localePreviewCache.clear();
          for (const row of rows) {
            const localeCode = normalizeLanguage(row?.ui_locale);
            if (!localeCode) continue;
            localeProgressByLocale.set(localeCode, row);
          }

          renderLocaleProgress(rows, referenceLocale);
          setLocaleProgressSummary(summary);
          setLocaleDeployHint(summary);
          setLocaleFilterSummary();
          updateSelectOptionLabels();
          updateLanguageHealth();
          applyLocaleProgressFocus();
          setLocaleProgressFeedback('');
        } catch {
          localeProgressByLocale.clear();
          localePreviewCache.clear();
          renderLocaleProgress([], 'en');
          setLocaleProgressSummary(null);
          setLocaleDeployHint(null);
          setLocaleFilterSummary();
          updateSelectOptionLabels();
          updateLanguageHealth();
          setLocaleProgressFeedback(accountCopy.localeProgressLoadFailed, true);
        }
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const selected = normalizeLanguage(select.value);
        if (!isAllowedLanguage(selected)) {
          setFeedback(accountCopy.chooseSupportedLanguage, true);
          return;
        }

        setFeedback(accountCopy.savingPreference);
        try {
          const response = await fetch(`${authBase}/api/user-preferences/me`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
            body: JSON.stringify({
              data: {
                preferred_ui_language: selected,
              },
            }),
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || accountCopy.preferenceSaveFailed;
            setFeedback(message, true);
            return;
          }

          applyPreferredLanguage(selected);
          setFeedback(accountCopy.preferenceSavedRedirect);
          window.setTimeout(() => {
            window.location.assign(`/${selected}/`);
          }, 400);
        } catch {
          setFeedback(accountCopy.preferenceNetworkError, true);
        }
      });

      notificationsForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const digest = normalizeNotificationDigest(notificationsDigest.value);
        notificationsDigest.value = digest;

        setNotificationsFeedback(accountCopy.notificationsSaving);
        try {
          const response = await fetch(`${authBase}/api/user-preferences/me`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
            body: JSON.stringify({
              data: {
                notifications_site_enabled: Boolean(notificationsSite.checked),
                notifications_email_enabled: Boolean(notificationsEmail.checked),
                notifications_digest: digest,
              },
            }),
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || accountCopy.notificationsSaveFailed;
            setNotificationsFeedback(message, true);
            return;
          }

          applyNotificationPreference(payload?.data);
          setNotificationsFeedback(accountCopy.notificationsSaved);
        } catch {
          setNotificationsFeedback(accountCopy.notificationsNetworkError, true);
        }
      });

      onboardingForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        setOnboardingFeedback(accountCopy.onboardingSaving);

        try {
          const response = await fetch(`${authBase}/api/user-preferences/me`, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
            body: JSON.stringify({
              data: {
                onboarding_progress: {
                  profile_completed: Boolean(onboardingProfileCompleted.checked),
                  first_place_selected: Boolean(onboardingFirstPlaceSelected.checked),
                  first_post_started: Boolean(onboardingFirstPostStarted.checked),
                  share_prompt_seen: Boolean(onboardingSharePromptSeen.checked),
                  skipped: Boolean(onboardingSkipped.checked),
                },
              },
            }),
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || accountCopy.onboardingSaveFailed;
            setOnboardingFeedback(message, true);
            return;
          }

          applyOnboardingPreference(payload?.data);
          setOnboardingFeedback(accountCopy.onboardingSaved);
        } catch {
          setOnboardingFeedback(accountCopy.onboardingNetworkError, true);
        }
      });

      select.addEventListener('change', () => {
        updateLanguageHealth();
      });

      passwordForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(passwordForm);
        const currentPassword = String(formData.get('currentPassword') || '');
        const password = String(formData.get('password') || '');
        const passwordConfirmation = String(formData.get('passwordConfirmation') || '');

        if (!currentPassword || !password || !passwordConfirmation) {
          setPasswordFeedback(accountCopy.passwordRequired, true);
          return;
        }

        if (password.length < 8) {
          setPasswordFeedback(accountCopy.passwordLength, true);
          return;
        }

        if (password !== passwordConfirmation) {
          setPasswordFeedback(accountCopy.passwordMismatch, true);
          return;
        }

        if (password === currentPassword) {
          setPasswordFeedback(accountCopy.passwordSameAsCurrent, true);
          return;
        }

        setPasswordFeedback(accountCopy.passwordSaving);
        try {
          const response = await fetch(`${authBase}/api/auth/change-password`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
              Authorization: `Bearer ${session.jwt}`,
            },
            body: JSON.stringify({
              currentPassword,
              password,
              passwordConfirmation,
            }),
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || payload?.message || accountCopy.passwordSaveFailed;
            setPasswordFeedback(message, true);
            return;
          }

          setPasswordFeedback(accountCopy.passwordSavedReauth);
          passwordForm.reset();
          clearAuthSession();
          window.setTimeout(() => {
            window.location.assign(loginPath);
          }, 1100);
        } catch {
          setPasswordFeedback(accountCopy.passwordNetworkError, true);
        }
      });

      commentsRefreshButton.addEventListener('click', () => {
        loadComments();
      });

      commentsFilterSelect.addEventListener('change', () => {
        commentsFocusPending = false;
        commentsPanel.classList.remove('account-comments-focus');
        renderCommentsForCurrentFilter();
      });

      accountRequestsRefreshButton.addEventListener('click', () => {
        loadAccountRequests();
      });

      accountRequestsFilterSelect.addEventListener('change', () => {
        renderAccountRequestsForCurrentFilter();
      });

      accountRequestsForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        await submitAccountRequest();
      });

      localeProgressRefreshButton.addEventListener('click', () => {
        loadLocaleProgress();
      });

      localeProgressList.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const exportButton = target.closest('[data-account-locale-preview-export]');
        if (exportButton instanceof HTMLButtonElement) {
          const localeCode = normalizeLanguage(exportButton.getAttribute('data-locale-code') || '');
          exportLocalePreviewCsv(localeCode, exportButton);
          return;
        }

        const toggleButton = target.closest('[data-account-locale-preview-toggle]');
        if (!(toggleButton instanceof HTMLButtonElement)) return;

        const localeCode = normalizeLanguage(toggleButton.getAttribute('data-locale-code') || '');
        const previewNode = findLocalePreviewNode(localeCode);
        if (!(previewNode instanceof HTMLElement)) return;

        if (!previewNode.hidden) {
          previewNode.hidden = true;
          toggleButton.setAttribute('aria-expanded', 'false');
          toggleButton.querySelector('.ui-button-label')?.replaceChildren(accountCopy.localeProgressShowDetails);
          return;
        }

        loadLocalePreview(localeCode, previewNode, toggleButton);
      });

      localeProgressFilterSelect.addEventListener('change', () => {
        localePreviewCache.clear();
        localeProgressFocusLocale = '';
        localeProgressFocusPending = false;
        setLocaleFilterSummary();
        const previewNodes = localeProgressList.querySelectorAll('[data-account-locale-preview]');
        for (const node of previewNodes) {
          if (node instanceof HTMLElement) {
            node.hidden = true;
            node.innerHTML = '';
          }
        }
        const toggleButtons = localeProgressList.querySelectorAll('[data-account-locale-preview-toggle]');
        for (const button of toggleButtons) {
          if (button instanceof HTMLButtonElement) {
            button.setAttribute('aria-expanded', 'false');
            button.querySelector('.ui-button-label')?.replaceChildren(accountCopy.localeProgressShowDetails);
          }
        }
      });

      localeDeployCopyButton.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(deployCommandText);
          setLocaleDeployFeedback(accountCopy.localeProgressDeployCopyDone);
        } catch {
          setLocaleDeployFeedback(accountCopy.localeProgressDeployCopyFailed, true);
        }
      });

      localeReleaseCopyButton.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(releaseCommandText);
          setLocaleDeployFeedback(accountCopy.localeProgressDeployCopyReleaseDone);
        } catch {
          setLocaleDeployFeedback(accountCopy.localeProgressDeployCopyFailed, true);
        }
      });

      localeWorkflowCopyButton.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(workflowCommandText);
          setLocaleDeployFeedback(accountCopy.localeProgressDeployCopyWorkflowDone);
        } catch {
          setLocaleDeployFeedback(accountCopy.localeProgressDeployCopyFailed, true);
        }
      });

      commentsFilterSelect.value = initialCommentState;
      accountRequestsFilterSelect.value = initialRequestState;
      if (initialPreviewState === 'missing' || initialPreviewState === 'untranslated') {
        localeProgressFilterSelect.value = initialPreviewState;
      } else {
        localeProgressFilterSelect.value = 'all';
      }
      updateSelectOptionLabels();
      updateLanguageHealth();
      loadPreference();
      loadProfile();
      loadComments();
      loadAccountRequests();
      loadLocaleProgress();
    })();
  </script>

  <script is:inline define:vars={{ accountCopy }}>
    (() => {
      const section = document.querySelector('[data-account-saved-lists]');
      if (!(section instanceof HTMLElement)) return;

      const authBase = section.getAttribute('data-auth-base');
      const listNode = section.querySelector('[data-account-saved-lists-list]');
      const emptyNode = section.querySelector('[data-account-saved-lists-empty]');
      const feedbackNode = section.querySelector('[data-account-saved-lists-feedback]');
      const refreshButton = section.querySelector('[data-account-saved-lists-refresh]');
      const totalListsNode = section.querySelector('[data-account-saved-lists-total-lists]');
      const totalItemsNode = section.querySelector('[data-account-saved-lists-total-items]');
      const totalPostsNode = section.querySelector('[data-account-saved-lists-total-posts]');
      const totalPlacesNode = section.querySelector('[data-account-saved-lists-total-places]');
      if (
        !authBase ||
        !(listNode instanceof HTMLElement) ||
        !(emptyNode instanceof HTMLElement) ||
        !(feedbackNode instanceof HTMLElement) ||
        !(refreshButton instanceof HTMLButtonElement) ||
        !(totalListsNode instanceof HTMLElement) ||
        !(totalItemsNode instanceof HTMLElement) ||
        !(totalPostsNode instanceof HTMLElement) ||
        !(totalPlacesNode instanceof HTMLElement)
      ) {
        return;
      }

      const readSession = () => {
        try {
          const fromLocal = localStorage.getItem('geovito_auth_session');
          if (fromLocal) return JSON.parse(fromLocal);
          const fromSession = sessionStorage.getItem('geovito_auth_session');
          if (fromSession) {
            localStorage.setItem('geovito_auth_session', fromSession);
            return JSON.parse(fromSession);
          }
        } catch (_error) {
          return null;
        }
        return null;
      };

      const session = readSession();
      const jwt = typeof session?.jwt === 'string' ? session.jwt : '';
      if (!jwt) {
        section.hidden = true;
        return;
      }

      section.hidden = false;
      const escapeHtml = (value) =>
        String(value ?? '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');
      const setFeedback = (message, isError = false) => {
        feedbackNode.textContent = String(message || '');
        feedbackNode.classList.toggle('is-error', Boolean(isError));
      };
      const formatDate = (value) => {
        if (!value) return '-';
        const date = new Date(String(value));
        if (Number.isNaN(date.getTime())) return '-';
        return date.toLocaleString();
      };

      let currentLists = [];
      let currentItems = [];
      let isMutating = false;

      const normalizeCount = (value) => {
        const parsed = Number(value);
        if (!Number.isFinite(parsed) || parsed < 0) return 0;
        return Math.round(parsed);
      };
      const normalizeLang = (value) => {
        const lang = String(value || '').trim().toLowerCase();
        return lang || 'en';
      };
      const currentLanguage = normalizeLang(document.documentElement.lang || 'en');
      const buildTargetHref = (targetType, targetRef) => {
        const normalizedType = String(targetType || '').trim().toLowerCase();
        const normalizedRef = String(targetRef || '').trim().replace(/^\/+|\/+$/g, '');
        if (!normalizedRef) return '#';
        const encodedRef = encodeURIComponent(normalizedRef).replaceAll('%2F', '/');
        if (normalizedType === 'place') return `/${currentLanguage}/atlas/${encodedRef}/`;
        if (normalizedType === 'post') return `/${currentLanguage}/blog/${encodedRef}/`;
        return '#';
      };

      const renderStats = () => {
        const items = Array.isArray(currentItems) ? currentItems : [];
        const listTotal = Array.isArray(currentLists) ? currentLists.length : 0;
        const postTotal = items.filter((item) => String(item?.target_type || '').toLowerCase() === 'post').length;
        const placeTotal = items.filter((item) => String(item?.target_type || '').toLowerCase() === 'place').length;
        totalListsNode.textContent = String(listTotal);
        totalItemsNode.textContent = String(items.length);
        totalPostsNode.textContent = String(postTotal);
        totalPlacesNode.textContent = String(placeTotal);
      };

      const renderRows = () => {
        listNode.innerHTML = '';
        const lists = Array.isArray(currentLists) ? currentLists : [];
        const items = Array.isArray(currentItems) ? currentItems : [];
        emptyNode.hidden = lists.length > 0;
        if (lists.length === 0) return;

        const itemIndex = new Map();
        for (const item of items) {
          const listId = String(item?.list_id || '');
          if (!listId) continue;
          const row = itemIndex.get(listId) || [];
          row.push({
            item_id: String(item?.item_id || ''),
            target_type: String(item?.target_type || '').trim().toLowerCase(),
            target_ref: String(item?.target_ref || '').trim(),
            href: buildTargetHref(item?.target_type, item?.target_ref),
          });
          itemIndex.set(listId, row);
        }

        const fragment = document.createDocumentFragment();
        for (const row of lists) {
          const item = document.createElement('li');
          item.className = 'account-comment-item';
          const listId = String(row?.list_id || '');
          const title = String(row?.title || row?.slug || '-');
          const visibility = String(row?.visibility || '-');
          const updatedAt = formatDate(row?.updated_at || row?.created_at);
          const itemCount = normalizeCount(row?.item_count);
          const previewItems = (itemIndex.get(listId) || []).slice(0, 4).filter((entry) => entry?.target_ref);
          const previewMarkup =
            previewItems.length > 0
              ? previewItems
                  .map((entry) => {
                    const targetRef = String(entry?.target_ref || '');
                    const targetType = String(entry?.target_type || '');
                    const href = String(entry?.href || '#');
                    return `
                      <li class="account-comment-meta account-saved-item-row">
                        <span>${escapeHtml(targetRef)} (${escapeHtml(targetType)})</span>
                        <span class="account-locale-actions account-saved-item-actions">
                          <a class="ui-button ui-button-secondary ui-button-sm" href="${escapeHtml(href)}">
                            <span class="ui-button-label">${escapeHtml(accountCopy.savedListsOpenTarget)}</span>
                          </a>
                          <button
                            type="button"
                            class="ui-button ui-button-secondary ui-button-sm"
                            data-account-saved-item-remove
                            data-list-id="${escapeHtml(listId)}"
                            data-target-type="${escapeHtml(targetType)}"
                            data-target-ref="${escapeHtml(targetRef)}"
                          >
                            <span class="ui-button-label">${escapeHtml(accountCopy.savedListsRemoveItem)}</span>
                          </button>
                        </span>
                      </li>
                    `;
                  })
                  .join('')
              : `<li class="account-comment-meta">${escapeHtml(accountCopy.savedListsNoItemsInList)}</li>`;

          item.innerHTML = `
            <p class="account-comment-meta">
              <strong>${escapeHtml(title)}</strong>
            </p>
            <p class="account-comment-meta">
              <strong>${escapeHtml(accountCopy.savedListsVisibility)}:</strong> ${escapeHtml(visibility)}
              · <strong>${escapeHtml(accountCopy.savedListsItemsLabel)}:</strong> ${escapeHtml(String(itemCount))}
              · <strong>${escapeHtml(accountCopy.savedListsUpdatedAt)}:</strong> ${escapeHtml(updatedAt)}
            </p>
            <p class="account-comment-meta">
              <strong>${escapeHtml(accountCopy.savedListsRecentTargets)}:</strong>
            </p>
            <ul class="account-comments-list gv-stack">${previewMarkup}</ul>
          `;
          fragment.appendChild(item);
        }

        listNode.appendChild(fragment);
      };

      const load = async () => {
        setFeedback(accountCopy.savedListsLoading);
        try {
          const listResponse = await fetch(`${authBase}/api/user-saved-lists/me/lists?limit=200`, {
            headers: {
              Accept: 'application/json',
              Authorization: `Bearer ${jwt}`,
            },
          });

          if (!listResponse.ok) {
            if (listResponse.status === 401) {
              section.hidden = true;
              return;
            }
            if (listResponse.status === 404 || listResponse.status === 405) {
              section.hidden = true;
              return;
            }
            setFeedback(accountCopy.savedListsLoadFailed, true);
            return;
          }

          const listPayload = await listResponse.json().catch(() => ({}));
          currentLists = Array.isArray(listPayload?.data?.items) ? listPayload.data.items : [];

          const itemResponse = await fetch(`${authBase}/api/user-saved-lists/me/items?limit=500`, {
            headers: {
              Accept: 'application/json',
              Authorization: `Bearer ${jwt}`,
            },
          });
          if (itemResponse.ok) {
            const itemPayload = await itemResponse.json().catch(() => ({}));
            currentItems = Array.isArray(itemPayload?.data?.items) ? itemPayload.data.items : [];
          } else if (itemResponse.status === 404 || itemResponse.status === 405) {
            currentItems = [];
          } else {
            currentItems = [];
          }

          renderStats();
          renderRows();
          setFeedback('');
        } catch (_error) {
          setFeedback(accountCopy.savedListsLoadFailed, true);
        }
      };

      refreshButton.addEventListener('click', () => {
        load();
      });

      listNode.addEventListener('click', async (event) => {
        const target =
          event.target instanceof HTMLElement ? event.target.closest('[data-account-saved-item-remove]') : null;
        if (!(target instanceof HTMLButtonElement)) return;
        if (isMutating) return;

        const listId = String(target.getAttribute('data-list-id') || '').trim();
        const targetType = String(target.getAttribute('data-target-type') || '').trim().toLowerCase();
        const targetRef = String(target.getAttribute('data-target-ref') || '').trim();
        if (!listId || !targetType || !targetRef) return;

        const label = target.querySelector('.ui-button-label');
        target.disabled = true;
        if (label) label.textContent = accountCopy.savedListsRemovingItem;
        setFeedback(accountCopy.savedListsRemovingItem);
        isMutating = true;

        try {
          const response = await fetch(`${authBase}/api/user-saved-lists/me/items/toggle`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
              Authorization: `Bearer ${jwt}`,
            },
            body: JSON.stringify({
              list_id: listId,
              target_type: targetType,
              target_ref: targetRef,
              action: 'unsave',
            }),
          });
          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || accountCopy.savedListsRemoveFailed;
            setFeedback(message, true);
            target.disabled = false;
            if (label) label.textContent = accountCopy.savedListsRemoveItem;
            isMutating = false;
            return;
          }
          setFeedback(accountCopy.savedListsItemRemoved);
          await load();
        } catch (_error) {
          setFeedback(accountCopy.savedListsRemoveFailed, true);
          target.disabled = false;
          if (label) label.textContent = accountCopy.savedListsRemoveItem;
        } finally {
          isMutating = false;
        }
      });

      load();
    })();
  </script>

  <script is:inline define:vars={{ accountCopy }}>
    (() => {
      const section = document.querySelector('[data-account-follows]');
      if (!(section instanceof HTMLElement)) return;

      const authBase = section.getAttribute('data-auth-base');
      const listNode = section.querySelector('[data-account-follows-list]');
      const emptyNode = section.querySelector('[data-account-follows-empty]');
      const feedbackNode = section.querySelector('[data-account-follows-feedback]');
      const communityFeedbackNode = section.querySelector('[data-account-community-feedback]');
      const refreshButton = section.querySelector('[data-account-follows-refresh]');
      const usersCount = section.querySelector('[data-account-follows-users]');
      const placesCount = section.querySelector('[data-account-follows-places]');
      const communityCitizenCardNode = section.querySelector('[data-account-community-citizen-card]');
      const communityBadgesNode = section.querySelector('[data-account-community-badges]');
      const communityLoadedAtNode = section.querySelector('[data-account-community-loaded-at]');
      if (
        !authBase ||
        !(listNode instanceof HTMLElement) ||
        !(emptyNode instanceof HTMLElement) ||
        !(feedbackNode instanceof HTMLElement) ||
        !(communityFeedbackNode instanceof HTMLElement) ||
        !(refreshButton instanceof HTMLButtonElement) ||
        !(usersCount instanceof HTMLElement) ||
        !(placesCount instanceof HTMLElement) ||
        !(communityCitizenCardNode instanceof HTMLElement) ||
        !(communityBadgesNode instanceof HTMLElement) ||
        !(communityLoadedAtNode instanceof HTMLElement)
      ) {
        return;
      }

      const readSession = () => {
        try {
          const fromLocal = localStorage.getItem('geovito_auth_session');
          if (fromLocal) return JSON.parse(fromLocal);
          const fromSession = sessionStorage.getItem('geovito_auth_session');
          if (fromSession) {
            localStorage.setItem('geovito_auth_session', fromSession);
            return JSON.parse(fromSession);
          }
        } catch (_error) {
          return null;
        }
        return null;
      };

      const session = readSession();
      const jwt = typeof session?.jwt === 'string' ? session.jwt : '';
      if (!jwt) {
        section.hidden = true;
        return;
      }

      section.hidden = false;
      const escapeHtml = (value) =>
        String(value ?? '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');
      const setFeedback = (message, isError = false) => {
        feedbackNode.textContent = String(message || '');
        feedbackNode.classList.toggle('is-error', Boolean(isError));
      };
      const setCommunityFeedback = (message, isError = false) => {
        communityFeedbackNode.textContent = String(message || '');
        communityFeedbackNode.classList.toggle('is-error', Boolean(isError));
      };
      const formatDate = (value) => {
        if (!value) return '-';
        const date = new Date(String(value));
        if (Number.isNaN(date.getTime())) return '-';
        return date.toLocaleString();
      };
      const toBoolLabel = (value) => {
        if (value === true) return accountCopy.communityVisibilityEnabled;
        if (value === false) return accountCopy.communityVisibilityDisabled;
        return accountCopy.communityVisibilityUnknown;
      };
      const resetCommunityVisibilityView = () => {
        communityCitizenCardNode.textContent = accountCopy.communityVisibilityUnknown;
        communityBadgesNode.textContent = accountCopy.communityVisibilityUnknown;
        communityLoadedAtNode.textContent = accountCopy.communityVisibilityUnknown;
        setCommunityFeedback('');
      };
      const loadCommunityVisibility = async () => {
        resetCommunityVisibilityView();
        try {
          const response = await fetch(`${authBase}/api/community-settings/effective`, {
            headers: {
              Accept: 'application/json',
              Authorization: `Bearer ${jwt}`,
            },
          });
          const payload = await response.json().catch(() => ({}));
          if (response.status === 403) {
            setCommunityFeedback(accountCopy.communityVisibilityLimited);
            return;
          }
          if (!response.ok) {
            setCommunityFeedback(accountCopy.communityVisibilityLoadFailed, true);
            return;
          }
          const data = payload?.data && typeof payload.data === 'object' ? payload.data : {};
          communityCitizenCardNode.textContent = toBoolLabel(data.citizen_card_visible);
          communityBadgesNode.textContent = toBoolLabel(data.badges_visible);
          communityLoadedAtNode.textContent = formatDate(new Date().toISOString());
          setCommunityFeedback('');
        } catch (_error) {
          setCommunityFeedback(accountCopy.communityVisibilityLoadFailed, true);
        }
      };

      let currentRows = [];
      let followEnabled = true;

      const renderCounts = (rows) => {
        const list = Array.isArray(rows) ? rows : [];
        const userTotal = list.filter((row) => String(row?.target_type || '') === 'user').length;
        const placeTotal = list.filter((row) => String(row?.target_type || '') === 'place').length;
        usersCount.textContent = String(userTotal);
        placesCount.textContent = String(placeTotal);
      };

      const renderRows = (rows) => {
        listNode.innerHTML = '';
        const list = Array.isArray(rows) ? rows : [];
        emptyNode.hidden = list.length > 0;
        if (list.length === 0) return;

        const fragment = document.createDocumentFragment();
        for (const row of list) {
          const item = document.createElement('li');
          item.className = 'account-comment-item';
          const targetType = String(row?.target_type || '-');
          const targetRef = String(row?.target_ref || '-');
          const status = String(row?.status || '-');
          const changed = formatDate(row?.last_toggled_at || row?.updated_at);

          item.innerHTML = `
            <p class="account-comment-meta">
              <strong>${escapeHtml(accountCopy.followsType)}:</strong> ${escapeHtml(targetType)}
              · <strong>${escapeHtml(accountCopy.followsTarget)}:</strong> ${escapeHtml(targetRef)}
              · <strong>${escapeHtml(accountCopy.followsStatus)}:</strong> ${escapeHtml(status)}
              · <strong>${escapeHtml(accountCopy.followsLastChanged)}:</strong> ${escapeHtml(changed)}
            </p>
            <div class="account-locale-actions">
              <button
                type="button"
                class="ui-button ui-button-secondary ui-button-sm"
                data-account-follow-remove
                data-target-type="${escapeHtml(targetType)}"
                data-target-ref="${escapeHtml(targetRef)}"
              >
                <span class="ui-button-label">${escapeHtml(accountCopy.followsUnfollow)}</span>
              </button>
            </div>
          `;
          fragment.appendChild(item);
        }

        listNode.appendChild(fragment);
      };

      const fetchRows = async () => {
        const response = await fetch(`${authBase}/api/user-follows/me/list?limit=500`, {
          headers: {
            Accept: 'application/json',
            Authorization: `Bearer ${jwt}`,
          },
        });
        const payload = await response.json().catch(() => ({}));
        return {
          ok: response.ok,
          status: response.status,
          payload,
        };
      };

      const load = async () => {
        setFeedback(accountCopy.followsLoading);
        try {
          const result = await fetchRows();
          if (!result.ok) {
            if (result.status === 401) {
              section.hidden = true;
              return;
            }
            setFeedback(accountCopy.followsLoadFailed, true);
            return;
          }

          const data = result.payload?.data && typeof result.payload.data === 'object' ? result.payload.data : {};
          followEnabled = data.follow_system_enabled === true;
          currentRows = Array.isArray(data.items) ? data.items : [];

          renderCounts(currentRows);
          renderRows(currentRows);
          if (!followEnabled) {
            setFeedback(accountCopy.followsDisabled);
            return;
          }
          setFeedback('');
        } catch (_error) {
          setFeedback(accountCopy.followsLoadFailed, true);
        }
      };

      listNode.addEventListener('click', async (event) => {
        const target = event.target instanceof HTMLElement ? event.target.closest('[data-account-follow-remove]') : null;
        if (!(target instanceof HTMLButtonElement)) return;
        if (!followEnabled) {
          setFeedback(accountCopy.followsDisabled);
          return;
        }

        const targetType = String(target.getAttribute('data-target-type') || '').trim().toLowerCase();
        const targetRef = String(target.getAttribute('data-target-ref') || '').trim().toLowerCase();
        if (!targetType || !targetRef) return;

        const label = target.querySelector('.ui-button-label');
        target.disabled = true;
        if (label) label.textContent = accountCopy.followsUnfollowing;
        setFeedback(accountCopy.followsUnfollowing);

        try {
          const response = await fetch(`${authBase}/api/user-follows/me/toggle`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
              Authorization: `Bearer ${jwt}`,
            },
            body: JSON.stringify({
              target_type: targetType,
              target_ref: targetRef,
              action: 'unfollow',
            }),
          });

          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            const message = payload?.error?.message || accountCopy.followsUnfollowFailed;
            setFeedback(message, true);
            target.disabled = false;
            if (label) label.textContent = accountCopy.followsUnfollow;
            return;
          }

          setFeedback(accountCopy.followsUpdated);
          await load();
        } catch (_error) {
          setFeedback(accountCopy.followsUnfollowFailed, true);
          target.disabled = false;
          if (label) label.textContent = accountCopy.followsUnfollow;
        }
      });

      refreshButton.addEventListener('click', () => {
        load();
        loadCommunityVisibility();
      });

      load();
      loadCommunityVisibility();
    })();
  </script>
</MainLayout>

