---
import MainLayout from '../../../layouts/MainLayout.astro';
import StateBanner from '../../../components/StateBanner.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import { resolveTranslation } from '../../../lib/languageState';
import { getBlogPosts } from '../../../lib/strapi';
import { isSupportedLanguage, pathForLanguage, SUPPORTED_LANGUAGES } from '../../../lib/languages';
import { absoluteUrl, buildLanguageLinks, languagePathMap, toAlternates } from '../../../lib/pageHelpers';
import { getUiMessages, translate } from '../../../lib/uiLanguage';
import { isPostInReview, isPostVisibleOnSite } from '../../../lib/ugcPostRules';

export async function getStaticPaths() {
  return SUPPORTED_LANGUAGES.map((language) => ({
    params: { lang: language },
  }));
}

const lang = Astro.params.lang || '';
if (!isSupportedLanguage(lang)) {
  throw new Error(`Unsupported language: ${lang}`);
}

const ui = getUiMessages(lang);
const posts = await getBlogPosts();
const hasMockContent = posts.some((post) => post.mock === true);

const entries = posts
  .map((post) => {
    if (!isPostVisibleOnSite(post)) {
      return null;
    }

    const resolved = resolveTranslation(post.translations, lang, post.canonical_language);
    const requested = resolved.requested;
    const complete = resolved.complete;
    const canonicalTranslation =
      Array.isArray(post.translations) && post.translations.length > 0
        ? post.translations.find(
            (entry) =>
              String(entry?.language || '').toLowerCase() === String(post.canonical_language || 'en').toLowerCase()
          ) || post.translations[0]
        : null;
    const output = resolved.output || (isPostInReview(post) ? requested || canonicalTranslation : null);
    const slug = requested?.slug || complete?.slug || canonicalTranslation?.slug || '';

    if (!slug || !output) {
      return null;
    }

    return {
      post_id: post.post_id,
      title: output.title || post.post_id,
      excerpt: output.excerpt || '',
      href: `/${lang}/blog/${slug}/`,
      status: requested?.status || 'missing',
      published_on: post.published_on || '',
      inReview: isPostInReview(post),
    };
  })
  .filter(Boolean);

const languageLinks = buildLanguageLinks(languagePathMap((language) => pathForLanguage(language, 'blog')));
const alternates = toAlternates(languageLinks);
const canonical = absoluteUrl(pathForLanguage(lang, 'blog'));
const robots = hasMockContent ? 'noindex,nofollow' : 'index,follow';
const reviewEntryCount = entries.filter((entry) => entry?.inReview).length;
const statusLabel = (state: string) => translate(ui, `stateBanner.state.${String(state || 'missing').toLowerCase()}`, {}, state || 'missing');
---

<MainLayout
  title={translate(ui, 'blog.listTitle')}
  description={translate(ui, 'blog.listDescription')}
  canonical={canonical}
  robots={robots}
  currentLanguage={lang}
  languageLinks={languageLinks}
  alternates={alternates}
  ui={ui}
  showTools={false}
  pageSurface="blog-listing"
>
  {hasMockContent ? <StateBanner status="mock" language={lang} canonicalPath={canonical} ui={ui} /> : null}

  <div class="blog-listing-page stack-lg section-gap-md">
    <section class="blog-listing-intro card-base card-editorial surface-elevated stack-md" data-blog-listing-intro>
      <div class="blog-listing-head stack-sm">
        <p class="type-label">{translate(ui, 'nav.blog', {}, 'Blog')}</p>
        <h1 class="type-h1">{translate(ui, 'blog.listTitle')}</h1>
        <p class="type-body-lg blog-listing-lead">
          {translate(
            ui,
            'blog.listLead',
            {},
            'Curated stories from places, routes, and community insights across Geovito.'
          )}
        </p>
      </div>
      <div class="blog-listing-meta stack-sm">
        <p class="type-body-sm">{translate(ui, 'blog.listHint')}</p>
        <div class="blog-listing-meta-chips" data-blog-listing-meta-chips>
          <span class="status-pill blog-listing-chip">
            {translate(ui, 'blog.listMetaSummary', { count: String(entries.length) }, '{count} posts')}
          </span>
          {
            reviewEntryCount > 0 ? (
              <span class="status-pill blog-listing-chip">
                {translate(ui, 'blog.listReviewSummary', { count: String(reviewEntryCount) }, '{count} in review')}
              </span>
            ) : null
          }
        </div>
      </div>
    </section>

    <section class="blog-listing-results stack-md" data-blog-listing-results>
      {
        entries.length > 0 ? (
          <ul class="blog-listing-grid" data-blog-listing-grid>
            {entries.map((entry) => (
              <li class="blog-listing-item card-base card-editorial panel" data-blog-listing-card>
                <div class="blog-listing-item-head stack-sm">
                  <a class="blog-listing-item-title type-title" href={entry?.href || '#'} data-blog-listing-title>
                    {entry?.title}
                  </a>
                  <div class="blog-listing-item-meta chip-row">
                    <span class="status-pill blog-listing-chip">{statusLabel(entry?.status || 'missing')}</span>
                    {entry?.inReview ? <span class="status-pill blog-listing-chip">{translate(ui, 'blog.reviewBadge', {}, 'In review')}</span> : null}
                    <span class="type-meta blog-listing-date">
                      {translate(ui, 'blog.publishedLabel', {}, 'Published')}:{' '}
                      {entry?.published_on || translate(ui, 'blog.publishedUnknown', {}, 'Unknown')}
                    </span>
                  </div>
                </div>
                <p class="type-body-sm blog-listing-item-excerpt">
                  {entry?.excerpt || translate(ui, 'blog.listExcerptFallback', {}, 'No summary yet.')}
                </p>
              </li>
            ))}
          </ul>
        ) : (
          <div data-blog-listing-empty>
            <EmptyState
              title={translate(ui, 'blog.listEmptyTitle', {}, 'No posts available yet')}
              description={translate(ui, 'blog.listEmptyDescription', {}, 'New editorial stories will appear here once published.')}
              icon="FileText"
            />
          </div>
        )
      }
    </section>
  </div>
</MainLayout>
