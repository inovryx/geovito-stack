  activityWarnOnlyEmpty: translate(ui, 'dashboard.activityWarnOnlyEmpty', {}, 'No warnings right now.'),
  activityNow: translate(ui, 'dashboard.activityNow', {}, 'just now'),
  activityClearHistory: translate(ui, 'dashboard.activityClearHistory', {}, 'Clear history'),
  activityClearHistoryDone: translate(ui, 'dashboard.activityClearHistoryDone', {}, 'Activity history cleared.'),
  refresh: translate(ui, 'dashboard.refresh', {}, 'Refresh'),
  loading: translate(ui, 'dashboard.loading', {}, 'Loading dashboard data...'),
  loadFailed: translate(ui, 'dashboard.loadFailed', {}, 'Some dashboard cards could not be loaded.'),
  moduleNavTitle: translate(ui, 'dashboard.moduleNavTitle', {}, 'Dashboard modules'),
  moduleGeneral: translate(ui, 'dashboard.moduleGeneral', {}, 'General'),
  moduleSeo: translate(ui, 'dashboard.moduleSeo', {}, 'SEO'),
  moduleAds: translate(ui, 'dashboard.moduleAds', {}, 'Ads'),
  moduleModeration: translate(ui, 'dashboard.moduleModeration', {}, 'Moderation'),
  moduleTranslation: translate(ui, 'dashboard.moduleTranslation', {}, 'Translation'),
  moduleSettings: translate(ui, 'dashboard.moduleSettings', {}, 'Settings'),
  moduleGeneralBody: translate(
    ui,
    'dashboard.moduleGeneralBody',
    {},
    'Session, profile status, and personal quick actions.'
  ),
  moduleModerationBody: translate(
    ui,
    'dashboard.moduleModerationBody',
    {},
    'Queue health, pending alerts, and moderation history.'
  ),
  moduleTranslationBody: translate(
    ui,
    'dashboard.moduleTranslationBody',
    {},
    'Locale coverage, missing keys, and deploy-required locales.'
  ),
  moduleSeoBody: translate(
    ui,
    'dashboard.moduleSeoBody',
    {},
    'Canonical, robots, and sitemap verification checkpoints.'
  ),
  moduleAdsBody: translate(
    ui,
    'dashboard.moduleAdsBody',
    {},
    'Consent-gated ad placement and CLS-safe slot policies.'
  ),
  moduleSettingsBody: translate(
    ui,
    'dashboard.moduleSettingsBody',
    {},
    'Account routing and role-based operational visibility.'
  ),
  moduleRoleMember: translate(ui, 'dashboard.moduleRoleMember', {}, 'Member'),
  moduleRoleEditor: translate(ui, 'dashboard.moduleRoleEditor', {}, 'Editor+'),
  moduleRoleAdmin: translate(ui, 'dashboard.moduleRoleAdmin', {}, 'Admin+'),
};
---

<MainLayout
  title={dashboardCopy.title}
  description={dashboardCopy.description}
  canonical={canonical}
  robots="noindex,nofollow"
  currentLanguage={lang}
  languageLinks={languageLinks}
  alternates={alternates}
  ui={ui}
  showTools={true}
  toolsContext={dashboardCopy.title}
>
  <h1>{dashboardCopy.title}</h1>
  <p class="small">{dashboardCopy.description}</p>

  <section class="card panel gv-stack" data-dashboard-logged-out hidden>
    <h2>{dashboardCopy.loginRequiredTitle}</h2>
    <p class="small">{dashboardCopy.loginRequiredBody}</p>
    <a class="ui-button ui-button-primary ui-button-md" href={loginPath}>{dashboardCopy.loginCta}</a>
  </section>

  <section class="dashboard-shell gv-stack" data-dashboard-authenticated hidden>
    <div class="dashboard-head">
      <p class="small" data-dashboard-feedback aria-live="polite">{dashboardCopy.loading}</p>
      <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-refresh>
        <span class="ui-button-label">{dashboardCopy.refresh}</span>
      </button>
    </div>

    <nav class="dashboard-section-nav" aria-label={dashboardCopy.moduleNavTitle}>
      <a
        class="dashboard-section-pill"
        href="#dashboard-member"
        data-dashboard-section-pill
        data-dashboard-target-lane="dashboard-member"
        data-dashboard-role-gated
        data-min-role="member"
      >
        {dashboardCopy.moduleGeneral}
      </a>
      <a
        class="dashboard-section-pill"
        href="#dashboard-control"
        data-dashboard-section-pill
        data-dashboard-target-lane="dashboard-control"
        data-dashboard-role-gated
        data-min-role="admin"
        hidden
      >
        {dashboardCopy.moduleSeo}
      </a>
      <a
        class="dashboard-section-pill"
        href="#dashboard-control-ads"
        data-dashboard-section-pill
        data-dashboard-target-lane="dashboard-control"
        data-dashboard-role-gated
        data-min-role="admin"
        hidden
      >
        {dashboardCopy.moduleAds}
      </a>
      <a
        class="dashboard-section-pill"
        href="#dashboard-editorial-moderation"
        data-dashboard-section-pill
        data-dashboard-target-lane="dashboard-editorial"
        data-dashboard-role-gated
        data-min-role="editor"
        hidden
      >
        {dashboardCopy.moduleModeration}
      </a>
      <a
        class="dashboard-section-pill"
        href="#dashboard-editorial-locale"
        data-dashboard-section-pill
        data-dashboard-target-lane="dashboard-editorial"
        data-dashboard-role-gated
        data-min-role="editor"
        hidden
      >
        {dashboardCopy.moduleTranslation}
      </a>
      <a
        class="dashboard-section-pill"
        href="#dashboard-member-settings"
        data-dashboard-section-pill
        data-dashboard-target-lane="dashboard-member"
        data-dashboard-role-gated
        data-min-role="member"
      >
        {dashboardCopy.moduleSettings}
      </a>
    </nav>

    <div class="dashboard-module-grid" aria-label={dashboardCopy.moduleNavTitle}>
      <a
        class="dashboard-module-card"
        href="#dashboard-member"
        data-dashboard-module-link
        data-dashboard-role-gated
        data-min-role="member"
      >
        <span class="dashboard-module-role">{dashboardCopy.moduleRoleMember}</span>
        <strong>{dashboardCopy.moduleGeneral}</strong>
        <p>{dashboardCopy.moduleGeneralBody}</p>
      </a>
      <a
        class="dashboard-module-card"
        href="#dashboard-member-settings"
        data-dashboard-module-link
        data-dashboard-role-gated
        data-min-role="member"
      >
        <span class="dashboard-module-role">{dashboardCopy.moduleRoleMember}</span>
        <strong>{dashboardCopy.moduleSettings}</strong>
        <p>{dashboardCopy.moduleSettingsBody}</p>
      </a>
      <a
        class="dashboard-module-card"
        href="#dashboard-editorial-moderation"
        data-dashboard-module-link
        data-dashboard-role-gated
        data-min-role="editor"
        hidden
      >
        <span class="dashboard-module-role">{dashboardCopy.moduleRoleEditor}</span>
        <strong>{dashboardCopy.moduleModeration}</strong>
        <p>{dashboardCopy.moduleModerationBody}</p>
      </a>
      <a
        class="dashboard-module-card"
        href="#dashboard-editorial-locale"
        data-dashboard-module-link
        data-dashboard-role-gated
        data-min-role="editor"
        hidden
      >
        <span class="dashboard-module-role">{dashboardCopy.moduleRoleEditor}</span>
        <strong>{dashboardCopy.moduleTranslation}</strong>
        <p>{dashboardCopy.moduleTranslationBody}</p>
      </a>
      <a
        class="dashboard-module-card"
        href="#dashboard-control-seo"
        data-dashboard-module-link
        data-dashboard-role-gated
        data-min-role="admin"
        hidden
      >
        <span class="dashboard-module-role">{dashboardCopy.moduleRoleAdmin}</span>
        <strong>{dashboardCopy.moduleSeo}</strong>
        <p>{dashboardCopy.moduleSeoBody}</p>
      </a>
      <a
        class="dashboard-module-card"
        href="#dashboard-control-ads"
        data-dashboard-module-link
        data-dashboard-role-gated
        data-min-role="admin"
        hidden
      >
        <span class="dashboard-module-role">{dashboardCopy.moduleRoleAdmin}</span>
        <strong>{dashboardCopy.moduleAds}</strong>
        <p>{dashboardCopy.moduleAdsBody}</p>
      </a>
    </div>

    <div class="dashboard-lanes">
      <section class="dashboard-lane gv-stack" id="dashboard-member" data-dashboard-lane data-min-role="member">
        <header class="dashboard-lane-head">
          <div class="dashboard-lane-title-wrap">
            <h2 class="dashboard-lane-title">{dashboardCopy.overviewTitle}</h2>
            <p class="small">{dashboardCopy.quickBody}</p>
          </div>
          <button
            type="button"
            class="dashboard-lane-toggle"
            data-dashboard-lane-toggle
            aria-expanded="true"
            aria-label={`Toggle ${dashboardCopy.overviewTitle}`}
            title={`Toggle ${dashboardCopy.overviewTitle}`}
          >
            -
          </button>
          <p class="dashboard-role-pill">
            <span>{dashboardCopy.accessRole}</span>
            <strong data-dashboard-role>{dashboardCopy.accessMember}</strong>
          </p>
        </header>

        <div class="dashboard-grid" data-dashboard-lane-content>
          <article class="card panel gv-stack" id="dashboard-member-follow">
            <h3 class="dashboard-mini-title">{dashboardCopy.overviewTitle}</h3>
            <dl class="dashboard-dl">
              <div>
                <dt>{dashboardCopy.overviewIdentity}</dt>
                <dd data-dashboard-identity>{dashboardCopy.unknown}</dd>
              </div>
              <div>
                <dt>{dashboardCopy.overviewEmail}</dt>
                <dd data-dashboard-email>{dashboardCopy.unknown}</dd>
              </div>
              <div>
                <dt>{dashboardCopy.overviewStatus}</dt>
                <dd data-dashboard-status>{dashboardCopy.unknown}</dd>
              </div>
              <div>
                <dt>{dashboardCopy.overviewMemberSince}</dt>
                <dd data-dashboard-created>{dashboardCopy.unknown}</dd>
              </div>
              <div>
                <dt>{dashboardCopy.overviewLoginAt}</dt>
                <dd data-dashboard-loginat>{dashboardCopy.unknown}</dd>
              </div>
            </dl>
          </article>

          <article class="card panel gv-stack" id="dashboard-member-notifications">
            <h3 class="dashboard-mini-title">{dashboardCopy.preferenceTitle}</h3>
            <p class="small">{dashboardCopy.preferenceBody}</p>
            <p class="dashboard-kpi">
              <span>{dashboardCopy.preferenceValue}</span>
              <strong data-dashboard-preferred>{dashboardCopy.unknown}</strong>
            </p>
          </article>

          <article class="card panel gv-stack" id="dashboard-member-onboarding">
            <h3 class="dashboard-mini-title">{dashboardCopy.onboardingTitle}</h3>
            <p class="small">{dashboardCopy.onboardingBody}</p>
            <div class="dashboard-kpi-grid">
              <p class="dashboard-kpi">
                <span>{dashboardCopy.onboardingStatus}</span>
                <strong data-dashboard-onboarding-status>{dashboardCopy.onboardingStatusInProgress}</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.onboardingProgress}</span>
                <strong data-dashboard-onboarding-progress>0%</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.onboardingCompleted}</span>
                <strong data-dashboard-onboarding-completed>0/4</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.onboardingLoadedAt}</span>
                <strong data-dashboard-onboarding-loaded-at>{dashboardCopy.unknown}</strong>
              </p>
            </div>
            <p class="small" data-dashboard-onboarding-note hidden></p>
            <div class="dashboard-actions">
              <a class="ui-button ui-button-secondary ui-button-sm" href={`${accountPath}#onboarding-progress`}>
                <span class="ui-button-label">{dashboardCopy.quickAccount}</span>
              </a>
            </div>
          </article>

          <article class="card panel gv-stack" id="dashboard-member-follow">
            <h3 class="dashboard-mini-title">{dashboardCopy.followTitle}</h3>
            <p class="small">{dashboardCopy.followBody}</p>
            <div class="dashboard-kpi-grid">
              <p class="dashboard-kpi">
                <span>{dashboardCopy.followSystemState}</span>
                <strong data-dashboard-follow-system>{dashboardCopy.followStatusUnknown}</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.followTotal}</span>
                <strong data-dashboard-follow-total>0</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.followUsers}</span>
                <strong data-dashboard-follow-users>0</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.followPlaces}</span>
                <strong data-dashboard-follow-places>0</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.followLoadedAt}</span>
                <strong data-dashboard-follow-loaded-at>{dashboardCopy.followStatusUnknown}</strong>
              </p>
            </div>
            <p class="small" data-dashboard-follow-note hidden></p>
            <div class="dashboard-actions">
              <a class="ui-button ui-button-secondary ui-button-sm" href={`${accountPath}#follow-settings`}>
                <span class="ui-button-label">{dashboardCopy.followManage}</span>
              </a>
            </div>
          </article>

          <article class="card panel gv-stack">
            <h3 class="dashboard-mini-title">{dashboardCopy.notificationsTitle}</h3>
            <p class="small">{dashboardCopy.notificationsBody}</p>
            <div class="dashboard-kpi-grid">
              <p class="dashboard-kpi">
                <span>{dashboardCopy.notificationsSite}</span>
                <strong data-dashboard-notifications-site>{dashboardCopy.followStatusUnknown}</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.notificationsEmail}</span>
                <strong data-dashboard-notifications-email>{dashboardCopy.followStatusUnknown}</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.notificationsDigest}</span>
                <strong data-dashboard-notifications-digest>{dashboardCopy.notificationsDigestOff}</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.notificationsLoadedAt}</span>
                <strong data-dashboard-notifications-loaded-at>{dashboardCopy.followStatusUnknown}</strong>
              </p>
            </div>
            <p class="small" data-dashboard-notifications-note hidden></p>
            <div class="dashboard-actions">
              <a class="ui-button ui-button-secondary ui-button-sm" href={`${accountPath}#notification-preferences`}>
                <span class="ui-button-label">{dashboardCopy.notificationsManage}</span>
              </a>
            </div>
          </article>

          <article class="card panel gv-stack">
            <h3 class="dashboard-mini-title">{dashboardCopy.savedListsTitle}</h3>
            <p class="small">{dashboardCopy.savedListsBody}</p>
            <div class="dashboard-kpi-grid">
              <p class="dashboard-kpi">
                <span>{dashboardCopy.savedListsTotalLists}</span>
                <strong data-dashboard-saved-lists-total-lists>0</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.savedListsTotalItems}</span>
                <strong data-dashboard-saved-lists-total-items>0</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.savedListsTotalPosts}</span>
                <strong data-dashboard-saved-lists-total-posts>0</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.savedListsTotalPlaces}</span>
                <strong data-dashboard-saved-lists-total-places>0</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.savedListsLoadedAt}</span>
                <strong data-dashboard-saved-lists-loaded-at>{dashboardCopy.followStatusUnknown}</strong>
              </p>
            </div>
            <p class="small" data-dashboard-saved-lists-note hidden></p>
            <p class="small">{dashboardCopy.savedListsRecentItems}</p>
            <ul class="dashboard-mini-list" data-dashboard-saved-lists-items hidden></ul>
            <div class="dashboard-actions">
              <a class="ui-button ui-button-secondary ui-button-sm" href={`${accountPath}#saved-lists`}>
                <span class="ui-button-label">{dashboardCopy.savedListsManage}</span>
              </a>
            </div>
          </article>

          <article class="card panel gv-stack">
            <h3 class="dashboard-mini-title">{dashboardCopy.commentsTitle}</h3>
            <p class="small">{dashboardCopy.commentsBody}</p>
            <div class="dashboard-kpi-grid">
              <p class="dashboard-kpi"><span>{dashboardCopy.commentsTotal}</span><strong data-dashboard-comments-total>0</strong></p>
              <p class="dashboard-kpi"><span>{dashboardCopy.commentsPending}</span><strong data-dashboard-comments-pending>0</strong></p>
              <p class="dashboard-kpi"><span>{dashboardCopy.commentsApproved}</span><strong data-dashboard-comments-approved>0</strong></p>
              <p class="dashboard-kpi"><span>{dashboardCopy.commentsRejected}</span><strong data-dashboard-comments-rejected>0</strong></p>
            </div>
            <ul class="dashboard-mini-list" data-dashboard-comments-recent hidden></ul>
          </article>

          <article class="card panel gv-stack" id="dashboard-member-creator">
            <h3 class="dashboard-mini-title">{dashboardCopy.creatorTitle}</h3>
            <p class="small">{dashboardCopy.creatorBody}</p>
            <div class="dashboard-kpi-grid">
              <p class="dashboard-kpi">
                <span>{dashboardCopy.creatorUsername}</span>
                <strong data-dashboard-creator-username>-</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.creatorVisibility}</span>
                <strong data-dashboard-creator-visibility>-</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.creatorDrafts}</span>
                <strong data-dashboard-creator-drafts>0</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.creatorSubmitted}</span>
                <strong data-dashboard-creator-submitted>0</strong>
              </p>
              <p class="dashboard-kpi">
                <span>{dashboardCopy.creatorApproved}</span>
                <strong data-dashboard-creator-approved>0</strong>
              </p>
            </div>
            <p class="small" data-dashboard-creator-profile-note>{dashboardCopy.creatorNoProfile}</p>
            <p class="small" data-dashboard-creator-link-wrap hidden>
              <span>{dashboardCopy.creatorPublicLink}: </span>
              <a href="#" data-dashboard-creator-link target="_blank" rel="noopener noreferrer">/u/</a>
            </p>
            <div class="dashboard-actions">
              <button
                type="button"
                class="ui-button ui-button-secondary ui-button-sm"
                data-dashboard-copy-creator-link
                hidden
              >
                <span class="ui-button-label">{dashboardCopy.creatorCopyLink}</span>
              </button>
              <a
                class="ui-button ui-button-secondary ui-button-sm"
                href="#dashboard-editorial-moderation"
                data-dashboard-section-pill
                data-dashboard-role-gated
                data-min-role="editor"
                hidden
              >
                <span class="ui-button-label">{dashboardCopy.creatorModerationInbox}</span>
              </a>
            </div>
          </article>

          <article class="card panel gv-stack">
            <h3 class="dashboard-mini-title">{dashboardCopy.accessTitle}</h3>
            <p class="small">{dashboardCopy.accessBody}</p>
            <ul class="dashboard-capabilities">
              <li>
                <span>{dashboardCopy.capabilityModeration}</span>
                <strong data-dashboard-cap-moderation>{dashboardCopy.capabilityDisabled}</strong>
              </li>
              <li>
                <span>{dashboardCopy.capabilityLocale}</span>
                <strong data-dashboard-cap-locale>{dashboardCopy.capabilityDisabled}</strong>
              </li>
              <li>
                <span>{dashboardCopy.capabilityAdminTools}</span>
                <strong data-dashboard-cap-admin>{dashboardCopy.capabilityDisabled}</strong>
              </li>
            </ul>
          </article>

          <article class="card panel gv-stack" id="dashboard-member-settings">
            <h3 class="dashboard-mini-title">{dashboardCopy.quickTitle}</h3>
            <p class="small">{dashboardCopy.quickBody}</p>
            <div class="dashboard-actions">
              <a class="ui-button ui-button-secondary ui-button-sm" href={accountPath} data-dashboard-quick-id="account" data-dashboard-role-gated data-min-role="member">
                <span class="ui-button-label">{dashboardCopy.quickAccount}</span>
              </a>
              <a
                class="ui-button ui-button-secondary ui-button-sm"
                href="#dashboard-member-creator"
                data-dashboard-quick-id="creator-profile"
                data-dashboard-role-gated
                data-min-role="member"
              >
                <span class="ui-button-label">{dashboardCopy.creatorTitle}</span>
              </a>
              <a
                class="ui-button ui-button-secondary ui-button-sm"
                href={`${accountPath}?commentState=pending#comments`}
                data-dashboard-quick-id="comments"
                data-dashboard-role-gated
                data-min-role="member"
              >
                <span class="ui-button-label">{dashboardCopy.quickComments}</span>
              </a>
              <a
                class="ui-button ui-button-secondary ui-button-sm"
                href={`${accountPath}#locale-progress`}
                data-dashboard-quick-id="locale-progress"
                data-dashboard-role-gated
                data-min-role="editor"
                hidden
              >
                <span class="ui-button-label">{dashboardCopy.quickLocale}</span>
              </a>
              <a class="ui-button ui-button-secondary ui-button-sm" href={pathForLanguage(lang, 'atlas')} data-dashboard-quick-id="atlas" data-dashboard-role-gated data-min-role="member">
                <span class="ui-button-label">{dashboardCopy.quickAtlas}</span>
              </a>
              <a class="ui-button ui-button-secondary ui-button-sm" href={pathForLanguage(lang, 'blog')} data-dashboard-quick-id="blog" data-dashboard-role-gated data-min-role="member">
                <span class="ui-button-label">{dashboardCopy.quickBlog}</span>
              </a>
              <a
                class="ui-button ui-button-secondary ui-button-sm"
                href="#dashboard-editorial-moderation"
                data-dashboard-quick-id="moderation"
                data-dashboard-section-pill
                data-dashboard-role-gated
                data-min-role="editor"
                hidden
              >
                <span class="ui-button-label">{dashboardCopy.quickModeration}</span>
              </a>
              <a
                class="ui-button ui-button-secondary ui-button-sm"
                href="#dashboard-control"
                data-dashboard-quick-id="control"
                data-dashboard-section-pill
                data-dashboard-role-gated
                data-min-role="admin"
                hidden
              >
                <span class="ui-button-label">{dashboardCopy.quickControl}</span>
              </a>
              <a
                class="ui-button ui-button-secondary ui-button-sm"
                href="#dashboard-control"
                data-dashboard-quick-id="owner-ops"
                data-dashboard-section-pill
                data-dashboard-role-gated
                data-min-role="owner"
                hidden
              >
                <span class="ui-button-label">{dashboardCopy.quickOwnerOps}</span>
              </a>
            </div>
          </article>
        </div>
      </section>

      <section
        class="dashboard-lane gv-stack"
        id="dashboard-editorial"
        data-dashboard-lane
        data-min-role="editor"
        hidden
      >
        <header class="dashboard-lane-head">
          <div class="dashboard-lane-title-wrap">
            <h2 class="dashboard-lane-title">{dashboardCopy.localeTitle}</h2>
            <p class="small">{dashboardCopy.localeBody}</p>
          </div>
          <button
            type="button"
            class="dashboard-lane-toggle"
            data-dashboard-lane-toggle
            aria-expanded="true"
            aria-label={`Toggle ${dashboardCopy.localeTitle}`}
            title={`Toggle ${dashboardCopy.localeTitle}`}
          >
            -
          </button>
        </header>

        <div class="dashboard-grid" data-dashboard-lane-content>
          <article class="card panel gv-stack" id="dashboard-editorial-moderation">
            <div class="gv-stack dashboard-moderation-wrap" data-dashboard-moderation-wrap hidden>
              <h3 class="dashboard-mini-title">{dashboardCopy.moderationQueueTitle}</h3>
              <p class="small">{dashboardCopy.moderationQueueBody}</p>
              <div class="dashboard-kpi-grid">
                <p class="dashboard-kpi">
                  <span>{dashboardCopy.moderationQueuePendingCount}</span>
                  <strong data-dashboard-moderation-pending>0</strong>
                </p>
                <p class="dashboard-kpi">
                  <span>{dashboardCopy.moderationQueueStaleCount}</span>
                  <strong data-dashboard-moderation-stale>0</strong>
                </p>
                <p class="dashboard-kpi">
                  <span>{dashboardCopy.moderationQueueOldest}</span>
                  <strong data-dashboard-moderation-oldest>0h</strong>
                </p>
              </div>
