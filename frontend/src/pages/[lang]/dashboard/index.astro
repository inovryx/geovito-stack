          row.className = 'dashboard-mini-item';
          row.innerHTML = `<span>${escapeHtml(dashboardCopy.savedListsNoItems)}</span>`;
          host.appendChild(row);
          host.hidden = false;
          return;
        }

        const fragment = document.createDocumentFragment();
        candidates.forEach((item) => {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item';
          const listTitle = titleByListId.get(item.listId) || item.listId || dashboardCopy.unknown;
          const targetType = item.targetType || dashboardCopy.unknown;
          const targetHref = resolveSavedListTargetHref(item.targetType, item.targetRef);

          row.innerHTML = `
            <strong>${escapeHtml(listTitle)} · ${escapeHtml(targetType)}</strong>
            <span>${escapeHtml(item.targetRef)}</span>
            <div class="dashboard-actions">
              <a class="ui-button ui-button-secondary ui-button-sm" href="${escapeHtml(targetHref)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.savedListsOpenTarget)}</span>
              </a>
              <button
                type="button"
                class="ui-button ui-button-secondary ui-button-sm"
                data-dashboard-saved-remove
                data-list-id="${escapeHtml(item.listId)}"
                data-target-type="${escapeHtml(item.targetType)}"
                data-target-ref="${escapeHtml(item.targetRef)}"
              >
                <span class="ui-button-label">${escapeHtml(dashboardCopy.savedListsRemoveItem)}</span>
              </button>
            </div>
          `;
          fragment.appendChild(row);
        });

        host.appendChild(fragment);
        host.hidden = false;
      };

      const applySavedListsView = (listsPayload, itemsPayload, loadedAtIsoString) => {
        const lists = Array.isArray(listsPayload?.items) ? listsPayload.items : [];
        const items = Array.isArray(itemsPayload?.items) ? itemsPayload.items : [];
        ownerSavedItemsTotal = normalizeCount(items.length, 0);
        const postCount = items.filter((item) => String(item?.target_type || '').trim().toLowerCase() === 'post').length;
        const placeCount = items.filter((item) => String(item?.target_type || '').trim().toLowerCase() === 'place').length;

        setText(savedListsTotalListsNode, String(normalizeCount(lists.length, 0)));
        setText(savedListsTotalItemsNode, String(ownerSavedItemsTotal));
        setText(savedListsTotalPostsNode, String(normalizeCount(postCount, 0)));
        setText(savedListsTotalPlacesNode, String(normalizeCount(placeCount, 0)));
        setText(savedListsLoadedAtNode, formatDate(loadedAtIsoString));
        renderSavedListsItems(listsPayload, itemsPayload);
        if (toNode(savedListsNoteNode)) {
          toNode(savedListsNoteNode).hidden = true;
          toNode(savedListsNoteNode).textContent = '';
          toNode(savedListsNoteNode).classList.remove('is-error');
        }
      };

      const setFeedback = (message, isError = false) => {
        const el = toNode(feedback);
        if (!el) return;
        el.textContent = String(message || '');
        el.classList.toggle('is-error', Boolean(isError));
      };

      const setOwnerWidgetState = (node, state, statusNode, detailNode, statusText, detailText) => {
        const host = toNode(node);
        if (host) {
          host.dataset.state = String(state || 'unknown');
        }
        setText(statusNode, statusText);
        setText(detailNode, detailText);
      };

      const setOwnerWidgetBadge = (badgeNode, value, options = {}) => {
        const badge = toNode(badgeNode);
        if (!badge) return;
        const label = String(options?.label || '').trim();
        const criticalThresholdRaw = Number(options?.criticalThreshold);
        const criticalThreshold = Number.isFinite(criticalThresholdRaw) ? criticalThresholdRaw : 5;
        const count = Number(value || 0);
        if (!Number.isFinite(count) || count <= 0) {
          badge.hidden = true;
          badge.textContent = '0';
          badge.removeAttribute('data-level');
          badge.removeAttribute('title');
          badge.removeAttribute('aria-label');
          return;
        }
        const rounded = Math.round(count);
        const isCritical = rounded >= criticalThreshold;
        const tooltip = label ? `${label}: ${rounded}` : String(rounded);
        badge.hidden = false;
        badge.textContent = String(rounded);
        badge.dataset.level = isCritical ? 'critical' : 'default';
        badge.title = tooltip;
        badge.setAttribute('aria-label', tooltip);
      };

      const normalizeActivityEvent = (event) => {
        if (!event || typeof event !== 'object') return null;
        const message = String(event.message || '').trim();
        if (!message) return null;
        const levelRaw = String(event.level || 'info').trim().toLowerCase();
        const level =
          levelRaw === 'warn' || levelRaw === 'ok' || levelRaw === 'info'
            ? levelRaw
            : 'info';
        const actionLabel = String(event.actionLabel || '').trim();
        const actionHref = String(event.actionHref || '').trim();
        const tsNum = Number(event.ts);
        const ts = Number.isFinite(tsNum) ? tsNum : Date.now();
        return {
          level,
          message,
          actionLabel: actionLabel || undefined,
          actionHref: actionHref || undefined,
          ts,
        };
      };

      const dedupeActivityEvents = (events) => {
        if (!Array.isArray(events)) return [];
        const map = new Map();
        events.forEach((raw) => {
          const event = normalizeActivityEvent(raw);
          if (!event) return;
          const key = `${event.level}|${event.message}|${event.actionHref || ''}`;
          const prev = map.get(key);
          if (!prev || event.ts > prev.ts) {
            map.set(key, event);
          }
        });
        return Array.from(map.values())
          .sort((a, b) => b.ts - a.ts)
          .slice(0, ACTIVITY_HISTORY_LIMIT);
      };

      const readActivityHistory = () => {
        try {
          const raw = localStorage.getItem(ACTIVITY_HISTORY_STORAGE_KEY);
          if (!raw) return [];
          const parsed = JSON.parse(raw);
          return dedupeActivityEvents(parsed);
        } catch {
          return [];
        }
      };

      const persistActivityHistory = () => {
        try {
          localStorage.setItem(
            ACTIVITY_HISTORY_STORAGE_KEY,
            JSON.stringify(activityHistory.slice(0, ACTIVITY_HISTORY_LIMIT))
          );
        } catch {
          // ignore storage write failures (private mode / quota)
        }
      };

      const readLaneCollapsedState = () => {
        try {
          const raw = localStorage.getItem(LANE_STATE_STORAGE_KEY);
          if (!raw) return {};
          const parsed = JSON.parse(raw);
          if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return {};
          return parsed;
        } catch {
          return {};
        }
      };

      const persistLaneCollapsedState = () => {
        try {
          localStorage.setItem(LANE_STATE_STORAGE_KEY, JSON.stringify(laneCollapsedState));
        } catch {
          // ignore storage write failures (private mode / quota)
        }
      };

      const updateLaneCollapsedState = (laneNode, isCollapsed, { persist = true } = {}) => {
        if (!(laneNode instanceof HTMLElement)) return;
        const laneId = String(laneNode.id || '').trim();
        if (!laneId) return;

        laneNode.dataset.collapsed = isCollapsed ? 'true' : 'false';

        const contentNode = laneNode.querySelector('[data-dashboard-lane-content]');
        if (contentNode instanceof HTMLElement) {
          contentNode.hidden = isCollapsed;
        }

        const toggleNode = laneNode.querySelector('[data-dashboard-lane-toggle]');
        if (toggleNode instanceof HTMLButtonElement) {
          toggleNode.textContent = isCollapsed ? '+' : '-';
          toggleNode.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
        }

        laneCollapsedState[laneId] = Boolean(isCollapsed);
        if (persist) {
          persistLaneCollapsedState();
        }
      };

      const isLaneVisible = (laneNode) => laneNode instanceof HTMLElement && laneNode.hidden !== true;

      const getVisibleSectionLinks = () => {
        return sectionNavPillLinks.filter((link) => {
          if (!(link instanceof HTMLAnchorElement)) return false;
          return !link.hidden;
        });
      };

      const resolveModuleHash = (hash) => {
        const normalizedHash = String(hash || '').trim().toLowerCase();
        if (!normalizedHash) return '';
        return String(moduleHashAliases[normalizedHash] || normalizedHash);
      };
      const resolveSectionHash = (hash) => {
        const normalizedHash = resolveModuleHash(hash);
        return String(sectionHashAliases[normalizedHash] || normalizedHash);
      };

      const setActiveSectionPill = (hash) => {
        const visibleLinks = getVisibleSectionLinks();
        const visibleModuleCards = moduleCardLinks.filter((link) => {
          if (!(link instanceof HTMLAnchorElement)) return false;
          return !link.hidden;
        });
        sectionNavPillLinks.forEach((link) => {
          if (link instanceof HTMLElement) {
            link.classList.remove('is-active');
          }
        });
        moduleCardLinks.forEach((link) => {
          if (link instanceof HTMLElement) {
            link.classList.remove('is-active');
          }
        });

        if (visibleLinks.length === 0) return;

        const requestedHash = String(hash || '').trim();
        const normalizedHash = resolveSectionHash(requestedHash);
        const matchingLinks = visibleLinks.filter((link) => {
          const href = String(link.getAttribute('href') || '');
          return href === requestedHash || href === normalizedHash;
        });
        if (matchingLinks.length > 0) {
          matchingLinks.forEach((link) => link.classList.add('is-active'));
        } else {
          const fallbackHref = String(visibleLinks[0].getAttribute('href') || '').trim();
          visibleLinks
            .filter((link) => String(link.getAttribute('href') || '') === fallbackHref)
            .forEach((link) => link.classList.add('is-active'));
        }

        if (visibleModuleCards.length === 0) return;

        const matchingModuleCards = visibleModuleCards.filter((link) => {
          const href = String(link.getAttribute('href') || '');
          return href === requestedHash || resolveSectionHash(href) === normalizedHash;
        });
        if (matchingModuleCards.length > 0) {
          matchingModuleCards.forEach((link) => link.classList.add('is-active'));
          return;
        }

        const fallbackCard = visibleModuleCards[0];
        if (fallbackCard instanceof HTMLElement) {
          fallbackCard.classList.add('is-active');
        }
      };

      const getAllowedModules = (roleRank) => {
        return dashboardModuleOrder.filter((moduleKey) => {
          const module = dashboardModules[moduleKey];
          if (!module) return false;
          const minRoleRank = Number(roleRanks[String(module.minRole || 'member').toLowerCase()] ?? 0);
          return roleRank >= minRoleRank;
        });
      };

      const resolveModuleFromHash = (hash, roleRank) => {
        const normalizedHash = resolveModuleHash(hash);
        const allowedModules = getAllowedModules(roleRank);
        if (allowedModules.length === 0) {
          return {
            key: 'general',
            ...dashboardModules.general,
          };
        }

        const fromHash = allowedModules
          .map((moduleKey) => ({
            key: moduleKey,
            ...dashboardModules[moduleKey],
          }))
          .find((module) => String(module.hash || '') === normalizedHash);
        if (fromHash) return fromHash;

        const fallbackModuleKey = allowedModules[0];
        const fallbackModule = dashboardModules[fallbackModuleKey] || dashboardModules.general;
        return {
          key: fallbackModuleKey || 'general',
          ...fallbackModule,
        };
      };

      const applyModuleView = (hash, options = {}) => {
        const syncHash = options.syncHash !== false;
        const focusTarget = options.focusTarget === true;
        const requestedFocusTargetId = String(options.focusTargetId || '').trim();
        const module = resolveModuleFromHash(hash, currentRoleRank);
        if (!module) return null;

        const showAllAllowedLanes = String(module.key || '') === 'general';

        laneNodes.forEach((lane) => {
          if (!(lane instanceof HTMLElement)) return;
          const minRole = String(lane.getAttribute('data-min-role') || 'member').toLowerCase();
          const minRoleRank = Number(roleRanks[minRole] ?? 0);
          const hasRoleAccess = currentRoleRank >= minRoleRank;
          const shouldShow =
            hasRoleAccess &&
            (showAllAllowedLanes || String(lane.id || '') === String(module.laneId || ''));
          lane.hidden = !shouldShow;
          if (shouldShow) {
            const laneId = String(lane.id || '').trim();
            const isCollapsed = Boolean(laneCollapsedState[laneId]);
            updateLaneCollapsedState(lane, isCollapsed, { persist: false });
          }
        });

        const currentHash = String(window.location.hash || '').trim();
        if (syncHash && module.hash && module.hash !== currentHash) {
          try {
            history.replaceState(null, '', module.hash);
          } catch {
            // no-op
          }
        }
        setActiveSectionPill(hash || module.hash);

        try {
          window.dispatchEvent(
            new CustomEvent(DASHBOARD_NAV_SYNC_EVENT, {
              detail: { hash: String(module.hash || hash || '') },
            })
          );
        } catch {
          window.dispatchEvent(new Event(DASHBOARD_NAV_SYNC_EVENT));
        }

        if (focusTarget) {
          const targetId = String(requestedFocusTargetId || module.focusId || module.laneId || '').trim();
          if (targetId) {
            const targetNode = document.getElementById(targetId);
            if (targetNode instanceof HTMLElement) {
              targetNode.scrollIntoView({ block: 'start', behavior: 'smooth' });
            }
          }
        }

        return module;
      };

      const applyHashNavigation = (hash, options = {}) => {
        const requestedHash = String(hash || '').trim();
        if (!requestedHash.startsWith('#')) return null;
        const syncHash = options.syncHash !== false;
        const focusTargetId = String(options.focusTargetId || '').trim();
        if (syncHash) {
          try {
            history.replaceState(null, '', requestedHash);
          } catch {
            // no-op
          }
        }
        return applyModuleView(requestedHash, {
          syncHash: false,
          focusTarget: options.focusTarget === true,
          focusTargetId,
        });
      };

      const syncActiveSectionFromScroll = () => {
        setActiveSectionPill(window.location.hash);
      };

      const requestSectionSync = () => {
        if (sectionSyncFrame !== null) return;
        sectionSyncFrame = window.requestAnimationFrame(() => {
          sectionSyncFrame = null;
          syncActiveSectionFromScroll();
        });
      };

      const mergeActivityHistory = (events) => {
        if (!Array.isArray(events) || events.length === 0) return;
        activityHistory = dedupeActivityEvents([...events, ...activityHistory]);
        persistActivityHistory();
      };

      const relativeFormatter = (() => {
        try {
          return new Intl.RelativeTimeFormat(document.documentElement.lang || 'en', { numeric: 'auto' });
        } catch {
          return null;
        }
      })();

      const formatRelativeTime = (timestampMs) => {
        if (!Number.isFinite(timestampMs)) return dashboardCopy.unknown;
        const diffSeconds = Math.round((timestampMs - Date.now()) / 1000);
        const absSeconds = Math.abs(diffSeconds);

        if (absSeconds < 10) return dashboardCopy.activityNow;

        const units = [
          ['day', 86400],
          ['hour', 3600],
          ['minute', 60],
        ];
        for (const [unit, size] of units) {
          if (absSeconds >= size) {
            const value = Math.round(diffSeconds / size);
            if (relativeFormatter) {
              return relativeFormatter.format(value, unit);
            }
            return value < 0 ? `${Math.abs(value)}${String(unit).charAt(0)} ago` : `in ${value}${String(unit).charAt(0)}`;
          }
        }

        if (relativeFormatter) {
          return relativeFormatter.format(diffSeconds, 'second');
        }
        return dashboardCopy.activityNow;
      };

      const syncOwnerReleaseStatus = () => {
        const hasSignals =
          ownerPendingCount > 0 ||
          ownerStalePendingCount > 0 ||
          ownerLocaleGapCount > 0 ||
          ownerLocaleDeployCount > 0;
        const status = hasSignals
          ? dashboardCopy.ownerSummaryStatusAttention
          : dashboardCopy.ownerSummaryStatusLive;
        setText(ownerReleaseStatusNode, status);
        setText(controlReleaseStatusNode, status);
      };

      const syncOwnerWidgets = () => {
        const hasReleaseSha = Boolean(ownerFingerprintSha);
        const moderationHasPending = ownerPendingCount > 0;
        const moderationHasStale = ownerStalePendingCount > 0;
        const localeHasGaps = ownerLocaleGapCount > 0;
        const localeHasMissing = ownerLocaleMissingCount > 0;
        const localeHasUntranslated = ownerLocaleUntranslatedCount > 0;
        const localeNeedsDeploy = ownerLocaleDeployCount > 0;
        const followDisabled =
          followSystemEnabled === false || communitySettingsPayload?.follow_system_enabled === false;
        const notificationsBothDisabled =
          notificationsSiteEnabled === false && notificationsEmailEnabled === false;
        const noSavedSignals = ownerSavedItemsTotal <= 0;
        const ugcDisabled = communitySettingsPayload?.ugc_enabled === false;
        const localeIssueCount = Math.max(0, Number(ownerLocaleGapCount) + Number(ownerLocaleDeployCount));
        const releaseIssueCount = Number(moderationHasPending) + Number(moderationHasStale) + Number(localeHasGaps) + Number(localeNeedsDeploy);

        setText(ownerFollowTotalNode, String(normalizeCount(ownerFollowTotal, 0)));
        setText(ownerSavedItemsNode, String(normalizeCount(ownerSavedItemsTotal, 0)));
        setText(ownerNotificationSiteNode, followBoolLabel(notificationsSiteEnabled));
        setText(ownerNotificationEmailNode, followBoolLabel(notificationsEmailEnabled));

        const releaseState = !hasReleaseSha
          ? 'unknown'
          : moderationHasPending || moderationHasStale || localeHasGaps || localeNeedsDeploy
            ? 'warn'
            : 'ok';
        const releaseStatusText =
          releaseState === 'unknown'
            ? dashboardCopy.ownerSummaryStatusUnknown
            : releaseState === 'warn'
              ? dashboardCopy.ownerSummaryStatusAttention
              : dashboardCopy.ownerSummaryStatusLive;
        const releaseDetailText = hasReleaseSha
          ? dashboardCopy.activityBuildLive.replace('{sha}', ownerFingerprintSha)
          : dashboardCopy.activityBuildUnknown;
        setOwnerWidgetState(
          ownerWidgetReleaseNode,
          releaseState,
          ownerWidgetReleaseStateNode,
          ownerWidgetReleaseDetailNode,
          releaseStatusText,
          releaseDetailText
        );
        setOwnerWidgetBadge(ownerWidgetReleaseBadgeNode, releaseIssueCount, {
          label: dashboardCopy.ownerSummaryReleaseStatus,
          criticalThreshold: 3,
        });
        setText(controlPendingNode, String(ownerPendingCount));
        setText(controlLocaleGapsNode, String(ownerLocaleGapCount));

        const moderationState = moderationHasStale
          ? 'warn'
          : moderationHasPending
            ? 'info'
            : 'ok';
        let moderationDetailText = dashboardCopy.moderationQueueEmpty;
        if (moderationHasStale) {
          moderationDetailText = dashboardCopy.activityPendingStale
            .replace('{count}', String(ownerStalePendingCount))
            .replace('{hours}', String(moderationStaleThresholdHours));
        } else if (moderationHasPending) {
          moderationDetailText = dashboardCopy.activityPending.replace('{count}', String(ownerPendingCount));
        }
        setOwnerWidgetState(
          ownerWidgetModerationNode,
          moderationState,
          ownerWidgetModerationStateNode,
          ownerWidgetModerationDetailNode,
          moderationState === 'warn'
            ? dashboardCopy.activityLevelWarn
            : moderationState === 'info'
              ? dashboardCopy.activityLevelInfo
              : dashboardCopy.activityLevelOk,
          moderationDetailText
        );
        setOwnerWidgetBadge(ownerWidgetModerationBadgeNode, ownerPendingCount, {
          label: dashboardCopy.ownerSummaryPending,
          criticalThreshold: 5,
        });

        const localeState = localeHasMissing
          ? 'warn'
          : localeHasUntranslated || localeNeedsDeploy
            ? 'info'
            : 'ok';
        let localeDetailText = dashboardCopy.activityAllClear;
        if (localeHasGaps && localeNeedsDeploy) {
          localeDetailText = `${dashboardCopy.activityLocaleGaps.replace('{count}', String(ownerLocaleGapCount))} · ${dashboardCopy.activityLocaleDeploy.replace('{count}', String(ownerLocaleDeployCount))}`;
        } else if (localeHasGaps) {
          localeDetailText = dashboardCopy.activityLocaleGaps.replace('{count}', String(ownerLocaleGapCount));
        } else if (localeNeedsDeploy) {
          localeDetailText = dashboardCopy.activityLocaleDeploy.replace('{count}', String(ownerLocaleDeployCount));
        }
        setOwnerWidgetState(
          ownerWidgetLocaleNode,
          localeState,
          ownerWidgetLocaleStateNode,
          ownerWidgetLocaleDetailNode,
          localeState === 'warn'
            ? dashboardCopy.activityLevelWarn
            : localeState === 'info'
              ? dashboardCopy.activityLevelInfo
              : dashboardCopy.activityLevelOk,
          localeDetailText
        );
        setOwnerWidgetBadge(ownerWidgetLocaleBadgeNode, localeIssueCount, {
          label: dashboardCopy.ownerSummaryLocaleGaps,
          criticalThreshold: 5,
        });

        const communitySignals = [];
        if (ugcDisabled) {
          communitySignals.push(dashboardCopy.activityCommunityUgcDisabled);
        }
        if (followDisabled) {
          communitySignals.push(dashboardCopy.activityCommunityFollowDisabled);
        }
        if (notificationsSiteEnabled === false) {
          communitySignals.push(dashboardCopy.activityNotificationSiteDisabled);
        }
        if (notificationsEmailEnabled === false) {
          communitySignals.push(dashboardCopy.activityNotificationEmailDisabled);
        }
        if (noSavedSignals) {
          communitySignals.push(`${dashboardCopy.savedListsTotalItems}: 0`);
        }

        const hasCommunityInputs =
          communitySettingsPayload !== null ||
          followSystemEnabled !== null ||
          notificationsSiteEnabled !== null ||
          notificationsEmailEnabled !== null ||
          ownerSavedItemsTotal > 0 ||
          ownerFollowTotal > 0;
        let communityState = 'unknown';
        if (hasCommunityInputs) {
          if (ugcDisabled || (followDisabled && notificationsBothDisabled)) {
            communityState = 'warn';
          } else if (followDisabled || notificationsBothDisabled || noSavedSignals) {
            communityState = 'info';
          } else {
            communityState = 'ok';
          }
        }
        const communityStatusText =
          communityState === 'unknown'
            ? dashboardCopy.ownerSummaryStatusUnknown
            : communityState === 'warn'
              ? dashboardCopy.ownerSummaryStatusAttention
              : communityState === 'info'
                ? dashboardCopy.activityLevelInfo
                : dashboardCopy.ownerSummaryStatusLive;
        const communityDetailText = hasCommunityInputs
          ? communitySignals.length > 0
            ? communitySignals.slice(0, 2).join(' · ')
            : dashboardCopy.activityAllClear
          : dashboardCopy.communityLoadFailed;
        setOwnerWidgetState(
          ownerWidgetCommunityNode,
          communityState,
          ownerWidgetCommunityStateNode,
          ownerWidgetCommunityDetailNode,
          communityStatusText,
          communityDetailText
        );
        setOwnerWidgetBadge(ownerWidgetCommunityBadgeNode, communitySignals.length, {
          label: dashboardCopy.communityTitle,
          criticalThreshold: 3,
        });
      };

      const refreshOwnerFingerprint = async () => {
        try {
          const response = await fetch('/.well-known/geovito-build.json', {
            headers: { Accept: 'application/json' },
          });
          if (!response.ok) {
            ownerFingerprintSha = '';
            setText(ownerBuildShaNode, dashboardCopy.unknown);
            return;
          }
          const payload = await response.json().catch(() => null);
          const sha = String(payload?.build_sha7 || '').trim();
          ownerFingerprintSha = sha;
          setText(ownerBuildShaNode, sha || dashboardCopy.unknown);
        } catch {
          ownerFingerprintSha = '';
          setText(ownerBuildShaNode, dashboardCopy.unknown);
        }
      };

      const renderActivityFeed = (hasErrors = false, options = {}) => {
        const host = toNode(activityFeedNode);
        const empty = toNode(activityEmptyNode);
        if (!host) return;

        host.innerHTML = '';
        const nowTs = Date.now();
        const includeLive = !(options && options.includeLive === false);
        const shouldPersist = !(options && options.persist === false);
        const warnOnlyEnabled =
          activityWarnOnlyNode instanceof HTMLInputElement && activityWarnOnlyNode.checked;
        const events = [];

        if (includeLive) {
          if (ownerFingerprintSha) {
            events.push({
              level: 'info',
              message: dashboardCopy.activityBuildLive.replace('{sha}', ownerFingerprintSha),
              actionLabel: dashboardCopy.activityActionRunbook,
              actionHref: launchRunbookUrl,
              ts: nowTs,
            });
          } else {
            events.push({
              level: 'warn',
              message: dashboardCopy.activityBuildUnknown,
              actionLabel: dashboardCopy.activityActionRunbook,
              actionHref: launchRunbookUrl,
              ts: nowTs,
            });
          }

          if (ownerPendingCount > 0) {
            events.push({
              level: 'warn',
              message: dashboardCopy.activityPending.replace('{count}', String(ownerPendingCount)),
              actionLabel: dashboardCopy.activityActionModeration,
              actionHref: accountCommentPendingHref,
              ts: nowTs,
            });
          }

          if (ownerStalePendingCount > 0) {
            events.push({
              level: 'warn',
              message: dashboardCopy.activityPendingStale
                .replace('{count}', String(ownerStalePendingCount))
                .replace('{hours}', String(moderationStaleThresholdHours)),
              actionLabel: dashboardCopy.activityActionModeration,
              actionHref: accountCommentPendingHref,
              ts: nowTs,
            });
          }

          if (ownerLocaleGapCount > 0) {
            events.push({
              level: 'warn',
              message: dashboardCopy.activityLocaleGaps.replace('{count}', String(ownerLocaleGapCount)),
              actionLabel: dashboardCopy.activityActionTranslations,
              actionHref: editorialLocaleHref,
              ts: nowTs,
            });
          }

          if (ownerLocaleDeployCount > 0) {
            events.push({
              level: 'info',
              message: dashboardCopy.activityLocaleDeploy.replace('{count}', String(ownerLocaleDeployCount)),
              actionLabel: dashboardCopy.activityActionTranslations,
              actionHref: editorialLocaleHref,
              ts: nowTs,
            });
          }

          if (currentRoleRank >= Number(roleRanks.admin) && communitySettingsPayload) {
            if (communitySettingsPayload.ugc_enabled === false) {
              events.push({
                level: 'warn',
                message: dashboardCopy.activityCommunityUgcDisabled,
                actionLabel: dashboardCopy.communityManage,
                actionHref: communitySettingsAdminUrl,
                ts: nowTs,
              });
            }
            if (communitySettingsPayload.guest_comments_enabled === false) {
              events.push({
                level: 'info',
                message: dashboardCopy.activityCommunityGuestDisabled,
                actionLabel: dashboardCopy.communityManage,
                actionHref: communitySettingsAdminUrl,
                ts: nowTs,
              });
            }
            if (communitySettingsPayload.follow_system_enabled === false) {
              events.push({
                level: 'info',
                message: dashboardCopy.activityCommunityFollowDisabled,
                actionLabel: dashboardCopy.communityManage,
                actionHref: communitySettingsAdminUrl,
                ts: nowTs,
              });
            }
            if (communitySettingsPayload.citizen_card_visible === false) {
              events.push({
                level: 'info',
                message: dashboardCopy.activityCommunityCitizenCardDisabled,
                actionLabel: dashboardCopy.communityManage,
                actionHref: communitySettingsAdminUrl,
                ts: nowTs,
              });
            }
            if (communitySettingsPayload.badges_visible === false) {
              events.push({
                level: 'info',
                message: dashboardCopy.activityCommunityBadgesDisabled,
                actionLabel: dashboardCopy.communityManage,
                actionHref: communitySettingsAdminUrl,
                ts: nowTs,
              });
            }
          }

          if (notificationsSiteEnabled === false) {
            events.push({
              level: 'info',
              message: dashboardCopy.activityNotificationSiteDisabled,
              actionLabel: dashboardCopy.notificationsManage,
              actionHref: `${accountPath}#notification-preferences`,
              ts: nowTs,
            });
          }

          if (notificationsEmailEnabled === false) {
            events.push({
              level: 'info',
              message: dashboardCopy.activityNotificationEmailDisabled,
              actionLabel: dashboardCopy.notificationsManage,
              actionHref: `${accountPath}#notification-preferences`,
              ts: nowTs,
            });
          }

          if (hasErrors) {
            events.push({
              level: 'warn',
              message: dashboardCopy.activityLoadFailed,
              actionLabel: dashboardCopy.activityActionRunbook,
              actionHref: launchRunbookUrl,
              ts: nowTs,
            });
          }

          if (events.length <= 1 && !hasErrors && ownerPendingCount === 0 && ownerLocaleGapCount === 0 && ownerLocaleDeployCount === 0) {
            events.push({
              level: 'ok',
              message: dashboardCopy.activityAllClear,
              ts: nowTs,
            });
          }
        }

        const persistableEvents = includeLive
          ? events.filter((event) => event.level !== 'ok' && event.message !== dashboardCopy.activityWarnOnlyEmpty)
          : [];
        if (shouldPersist && persistableEvents.length > 0) {
          mergeActivityHistory(persistableEvents);
        }

        const sourceEvents = activityHistory.length > 0 ? activityHistory : events;
        let visibleEvents = warnOnlyEnabled
          ? sourceEvents.filter((event) => event.level === 'warn')
          : sourceEvents;
        if (warnOnlyEnabled && visibleEvents.length === 0) {
          visibleEvents = [
            {
              level: 'ok',
              message: dashboardCopy.activityWarnOnlyEmpty,
              ts: nowTs,
            },
          ];
        }

        const fragment = document.createDocumentFragment();
        visibleEvents.slice(0, 10).forEach((event) => {
          const row = document.createElement('li');
          row.className = `dashboard-activity-item dashboard-activity-item--${event.level}`;

          const head = document.createElement('div');
          head.className = 'dashboard-activity-head';

          const badge = document.createElement('strong');
          badge.textContent =
            event.level === 'ok'
              ? dashboardCopy.activityLevelOk
              : event.level === 'warn'
                ? dashboardCopy.activityLevelWarn
                : dashboardCopy.activityLevelInfo;
          head.appendChild(badge);

          const time = document.createElement('time');
          time.className = 'dashboard-activity-time';
          time.dateTime = new Date(Number(event.ts) || nowTs).toISOString();
          time.textContent = formatRelativeTime(Number(event.ts) || nowTs);
          head.appendChild(time);

          const text = document.createElement('span');
          text.textContent = event.message;
          row.appendChild(head);
          row.appendChild(text);

          if (event.actionLabel && event.actionHref) {
            const action = document.createElement('a');
            action.className = 'dashboard-activity-link';
            action.textContent = event.actionLabel;
            action.setAttribute('href', String(event.actionHref));
            if (/^https?:\/\//.test(String(event.actionHref))) {
              action.setAttribute('target', '_blank');
              action.setAttribute('rel', 'noopener noreferrer');
            }
            row.appendChild(action);
          }

          fragment.appendChild(row);
        });

        host.appendChild(fragment);
        host.hidden = visibleEvents.length === 0;
        if (empty) {
          empty.hidden = visibleEvents.length > 0;
        }
      };

      const startActivityTicker = () => {
        if (activityTickTimer) {
          clearInterval(activityTickTimer);
        }
        activityTickTimer = window.setInterval(() => {
          renderActivityFeed(lastActivityHasErrors, { includeLive: false, persist: false });
        }, 60000);
      };

      const escapeHtml = (value) =>
        String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');

      const readSession = () => {
        try {
          const fromLocal = localStorage.getItem('geovito_auth_session');
          const fromSession = sessionStorage.getItem('geovito_auth_session');
          const raw = fromLocal || fromSession;
          if (!raw) return null;

          if (!fromLocal && fromSession) {
            localStorage.setItem('geovito_auth_session', fromSession);
          }

          const parsed = JSON.parse(raw);
          if (!parsed || typeof parsed !== 'object') return null;
          const jwt = typeof parsed.jwt === 'string' ? parsed.jwt.trim() : '';
          if (!jwt) return null;

          return {
            jwt,
            email: typeof parsed.email === 'string' ? parsed.email.trim() : '',
            username: typeof parsed.username === 'string' ? parsed.username.trim() : '',
            loginAt: typeof parsed.loginAt === 'string' ? parsed.loginAt.trim() : '',
          };
        } catch {
          return null;
        }
      };

      const formatDate = (value) => {
        if (!value) return dashboardCopy.unknown;
        const date = new Date(String(value));
        if (Number.isNaN(date.getTime())) return dashboardCopy.unknown;
        try {
          return new Intl.DateTimeFormat(document.documentElement.lang || 'en', {
            dateStyle: 'medium',
            timeStyle: 'short',
          }).format(date);
        } catch {
          return date.toISOString();
        }
      };

      const normalizeLanguage = (value) => String(value || '').trim().toLowerCase();

      const getGovernanceCopy = (role) => {
        const normalized = String(role || '').toLowerCase();
        if (normalized === 'owner') {
          return {
            scope: dashboardCopy.roleGovernanceOwnerScope,
            policy: dashboardCopy.roleGovernanceOwnerPolicy,
          };
        }
        if (normalized === 'admin') {
          return {
            scope: dashboardCopy.roleGovernanceAdminScope,
            policy: dashboardCopy.roleGovernanceAdminPolicy,
          };
        }
        if (normalized === 'editor') {
          return {
            scope: dashboardCopy.roleGovernanceEditorScope,
            policy: dashboardCopy.roleGovernanceEditorPolicy,
          };
        }
        return {
          scope: dashboardCopy.roleGovernanceMemberScope,
          policy: dashboardCopy.roleGovernanceMemberPolicy,
        };
      };

      const inferRole = (userPayload, session) => {
        const roleRaw = String(
          userPayload?.role?.type ||
          userPayload?.role?.name ||
          userPayload?.role?.code ||
          ''
        ).trim().toLowerCase();

        if (roleRaw.includes('super') || roleRaw === 'admin' || roleRaw.includes('administrator')) {
          return 'admin';
        }
        if (roleRaw.includes('editor')) {
          return 'editor';
        }

        const email = normalizeLanguage(userPayload?.email || session?.email || '');
        if (ownerEmailHint && email && email === normalizeLanguage(ownerEmailHint)) {
          return 'owner';
        }

        return 'member';
      };

      const applyAccessView = (role, options = {}) => {
        const syncHash = options.syncHash !== false;
        const normalizedRole = String(role || 'member').toLowerCase();
        const isOwner = normalizedRole === 'owner';
        const isAdmin = isOwner || normalizedRole === 'admin';
        const isEditor = isAdmin || normalizedRole === 'editor';
        const effectiveRole = isOwner ? 'owner' : isAdmin ? 'admin' : isEditor ? 'editor' : 'member';
        const effectiveRoleRank = Number(roleRanks[effectiveRole] ?? 0);
        canRunModeration = isEditor;

        const roleLabel = isOwner
          ? dashboardCopy.accessOwner
          : isAdmin
            ? dashboardCopy.accessAdmin
            : isEditor
              ? dashboardCopy.accessEditor
              : dashboardCopy.accessMember;
        setText(roleNode, roleLabel);
        setText(governanceRoleNode, roleLabel);

        const governanceCopy = getGovernanceCopy(
          isOwner ? 'owner' : isAdmin ? 'admin' : isEditor ? 'editor' : 'member'
        );
        setText(governanceScopeNode, governanceCopy.scope);
        setText(governancePolicyNode, governanceCopy.policy);

        setText(capModerationNode, isEditor ? dashboardCopy.capabilityEnabled : dashboardCopy.capabilityDisabled);
        setText(capLocaleNode, isEditor ? dashboardCopy.capabilityEnabled : dashboardCopy.capabilityDisabled);
        setText(capAdminNode, isAdmin ? dashboardCopy.capabilityEnabled : dashboardCopy.capabilityDisabled);

        adminLinks.forEach((link) => {
          if (!(link instanceof HTMLElement)) return;
          link.hidden = !isAdmin;
        });

        copyCommandButtons.forEach((button) => {
          if (!(button instanceof HTMLElement)) return;
          button.hidden = !isAdmin;
        });

        if (toNode(controlNote)) {
          toNode(controlNote).hidden = isAdmin;
        }

        if (toNode(governanceLimitedNoteNode)) {
          toNode(governanceLimitedNoteNode).hidden = isAdmin;
        }

        if (toNode(moderationWrapNode)) {
          toNode(moderationWrapNode).hidden = !canRunModeration;
        }

        roleGatedNodes.forEach((node) => {
          if (!(node instanceof HTMLElement)) return;
          const minRole = String(node.getAttribute('data-min-role') || 'member').toLowerCase();
          const minRoleRank = Number(roleRanks[minRole] ?? 0);
          node.hidden = effectiveRoleRank < minRoleRank;
        });

        currentRoleRank = effectiveRoleRank;
        const activeModule = applyModuleView(window.location.hash, { syncHash, focusTarget: false });
        if (!activeModule) {
          setActiveSectionPill('');
        }

        return {
          isOwner,
          isAdmin,
          isEditor,
        };
      };

      const renderRecentComments = (items) => {
        const host = toNode(commentsRecentNode);
        if (!host) return;
        host.innerHTML = '';

        const list = Array.isArray(items) ? items.slice(0, 5) : [];
        host.hidden = list.length === 0;
        if (list.length === 0) return;

        const fragment = document.createDocumentFragment();
        list.forEach((item) => {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item';
          const status = String(item?.status || '').trim().toUpperCase() || '-';
          const body = String(item?.body || '').trim() || '-';
          const compactBody = body.length > 110 ? `${body.slice(0, 107)}...` : body;
          row.innerHTML = `<strong>${status}</strong><span>${compactBody}</span>`;
          fragment.appendChild(row);
        });

        host.appendChild(fragment);
      };

      const renderModerationQueue = (items, summary = null) => {
        const host = toNode(moderationListNode);
        if (!host) return;

        host.innerHTML = '';

        const sourceList = Array.isArray(items) ? items : [];
        let derivedStaleCount = 0;
        let derivedOldestHours = 0;
        const nowMs = Date.now();

        sourceList.forEach((item) => {
          const createdRaw = String(
            item?.created_at ||
            item?.createdAt ||
            item?.submitted_at ||
            ''
          ).trim();
          if (!createdRaw) return;

          const createdMs = new Date(createdRaw).getTime();
          if (!Number.isFinite(createdMs) || createdMs <= 0) return;

          const ageHours = Math.max(0, Math.floor((nowMs - createdMs) / 3600000));
          if (ageHours > derivedOldestHours) derivedOldestHours = ageHours;
          if (ageHours >= moderationStaleThresholdHours) derivedStaleCount += 1;
        });

        const summaryThreshold = normalizeCount(summary?.stale_threshold_hours, 0);
        if (summaryThreshold > 0) {
          moderationStaleThresholdHours = summaryThreshold;
        }

        const pendingCount = normalizeCount(summary?.pending_total, sourceList.length);
        const staleCount = normalizeCount(summary?.stale_pending_total, derivedStaleCount);
        const oldestHours = normalizeCount(summary?.oldest_pending_hours, derivedOldestHours);

        setText(moderationPendingNode, String(pendingCount));
        setText(moderationStaleNode, String(staleCount));
        setText(moderationOldestNode, `${oldestHours}h`);
        ownerStalePendingCount = staleCount;

        const alertEl = toNode(moderationAlertNode);
        if (alertEl) {
          if (staleCount > 0) {
            alertEl.hidden = false;
            alertEl.textContent = dashboardCopy.moderationQueueStaleAlert
              .replace('{count}', String(staleCount))
              .replace('{hours}', String(moderationStaleThresholdHours));
          } else {
            alertEl.hidden = true;
            alertEl.textContent = '';
          }
        }

        const list = sourceList.slice(0, 8);
        if (!canRunModeration || list.length === 0) {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item';
          row.innerHTML = `<span>${escapeHtml(dashboardCopy.moderationQueueEmpty)}</span>`;
          host.appendChild(row);
          return;
        }

        const fragment = document.createDocumentFragment();
        list.forEach((item) => {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item dashboard-moderation-item';
          const status = String(item?.status || '').trim().toUpperCase() || '-';
          const body = String(item?.body || '').trim() || '-';
          const compactBody = body.length > 120 ? `${body.slice(0, 117)}...` : body;
          const commentId = String(item?.comment_id || '').trim();
          const author = String(item?.display_name || item?.source || '').trim() || '-';
          const postRef = String(item?.blog_post_ref || '').trim() || '-';
          row.innerHTML = `
            <strong>${escapeHtml(status)} · ${escapeHtml(author)}</strong>
            <span>${escapeHtml(compactBody)}</span>
            <span>${escapeHtml(dashboardCopy.moderationHistoryPost)}: ${escapeHtml(postRef)}</span>
            <div class="dashboard-action-row">
              <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-moderate="approved" data-comment-id="${escapeHtml(commentId)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.moderationApprove)}</span>
              </button>
              <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-moderate="rejected" data-comment-id="${escapeHtml(commentId)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.moderationReject)}</span>
              </button>
              <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-moderate="spam" data-comment-id="${escapeHtml(commentId)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.moderationSpam)}</span>
              </button>
            </div>
          `;
          fragment.appendChild(row);
        });

        host.appendChild(fragment);
      };

      const renderModerationHistory = (items) => {
        const host = toNode(moderationHistoryNode);
        if (!host) return;

        host.innerHTML = '';
        const list = Array.isArray(items) ? items.slice(0, 8) : [];
        if (!canRunModeration || list.length === 0) {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item';
          row.innerHTML = `<span>${escapeHtml(dashboardCopy.moderationHistoryEmpty)}</span>`;
          host.appendChild(row);
          return;
        }

        const fragment = document.createDocumentFragment();
        list.forEach((item) => {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item';

          const status = String(item?.status || '').trim().toUpperCase() || '-';
          const reviewer = String(item?.reviewed_by || '').trim() || '-';
          const reviewedAt = String(item?.reviewed_at || item?.updated_at || '').trim();
          const reviewedAtLabel = reviewedAt ? formatDate(reviewedAt) : dashboardCopy.unknown;
          const body = String(item?.body || '').trim() || '-';
          const compactBody = body.length > 120 ? `${body.slice(0, 117)}...` : body;
          const postRef = String(item?.blog_post_ref || '').trim() || '-';
          const moderationNote = String(item?.moderation_notes || '').trim();

          row.innerHTML = `
            <strong>${escapeHtml(status)} · ${escapeHtml(reviewer)} · ${escapeHtml(reviewedAtLabel)}</strong>
            <span>${escapeHtml(compactBody)}</span>
            <span>${escapeHtml(dashboardCopy.moderationHistoryPost)}: ${escapeHtml(postRef)}</span>
            ${moderationNote ? `<span>${escapeHtml(dashboardCopy.moderationHistoryNote)}: ${escapeHtml(moderationNote)}</span>` : ''}
          `;
          fragment.appendChild(row);
        });

        host.appendChild(fragment);
      };

      const renderReportInbox = (items) => {
        const host = toNode(reportListNode);
        if (!host) return;
        host.innerHTML = '';

        const list = Array.isArray(items) ? items : [];
        const newCount = list.filter((item) => String(item?.status || '').toLowerCase() === 'new').length;
        const reviewingCount = list.filter((item) => String(item?.status || '').toLowerCase() === 'reviewing').length;
        const resolvedCount = list.filter((item) => {
          const status = String(item?.status || '').toLowerCase();
          return status === 'resolved' || status === 'dismissed';
        }).length;

        setText(reportNewNode, String(newCount));
        setText(reportReviewingNode, String(reviewingCount));
        setText(reportResolvedNode, String(resolvedCount));

        if (!canRunModeration || list.length === 0) {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item';
          row.innerHTML = `<span>${escapeHtml(dashboardCopy.reportInboxEmpty)}</span>`;
          host.appendChild(row);
          return;
        }

        const fragment = document.createDocumentFragment();
        list.slice(0, 8).forEach((item) => {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item dashboard-moderation-item';
          const reportId = String(item?.report_id || '').trim();
          const targetType = String(item?.target_type || '').trim().toUpperCase() || '-';
          const targetRef = String(item?.target_ref || '').trim() || '-';
          const reason = String(item?.reason || '').trim().toUpperCase() || '-';
          const status = String(item?.status || '').trim().toUpperCase() || '-';
          const createdLabel = formatDate(item?.created_at || item?.updated_at || '');

          row.innerHTML = `
            <strong>${escapeHtml(status)} · ${escapeHtml(reason)} · ${escapeHtml(createdLabel)}</strong>
            <span>${escapeHtml(dashboardCopy.reportInboxTarget)}: ${escapeHtml(targetType)} · ${escapeHtml(targetRef)}</span>
            <div class="dashboard-action-row">
              <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-report-set="reviewing" data-report-id="${escapeHtml(reportId)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.reportReview)}</span>
              </button>
              <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-report-set="resolved" data-report-id="${escapeHtml(reportId)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.reportResolve)}</span>
              </button>
              <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-report-set="dismissed" data-report-id="${escapeHtml(reportId)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.reportDismiss)}</span>
              </button>
            </div>
          `;
          fragment.appendChild(row);
        });

        host.appendChild(fragment);
      };

      const renderAccountRequestInbox = (items) => {
        const host = toNode(accountRequestListNode);
        if (!host) return;
        host.innerHTML = '';

        const list = Array.isArray(items) ? items : [];
        const newCount = list.filter((item) => String(item?.status || '').toLowerCase() === 'new').length;
        const approvedCount = list.filter((item) => String(item?.status || '').toLowerCase() === 'approved').length;
        const completedCount = list.filter((item) => String(item?.status || '').toLowerCase() === 'completed').length;

        setText(accountRequestNewNode, String(newCount));
        setText(accountRequestApprovedNode, String(approvedCount));
        setText(accountRequestCompletedNode, String(completedCount));

        if (!canRunModeration || list.length === 0) {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item';
          row.innerHTML = `<span>${escapeHtml(dashboardCopy.accountRequestsEmpty)}</span>`;
          host.appendChild(row);
          return;
        }

        const fragment = document.createDocumentFragment();
        list.slice(0, 8).forEach((item) => {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item dashboard-moderation-item';
          const requestId = String(item?.request_id || '').trim();
          const requestType = String(item?.request_type || '').trim().toUpperCase() || '-';
          const status = String(item?.status || '').trim().toUpperCase() || '-';
          const createdLabel = formatDate(item?.created_at || item?.updated_at || '');
          const reason = String(item?.reason || '').trim();
          const reasonLabel = reason.length > 140 ? `${reason.slice(0, 137)}...` : reason;

          row.innerHTML = `
            <strong>${escapeHtml(status)} · ${escapeHtml(createdLabel)}</strong>
            <span>${escapeHtml(dashboardCopy.accountRequestType)}: ${escapeHtml(requestType)}</span>
            ${reasonLabel ? `<span>${escapeHtml(reasonLabel)}</span>` : ''}
            <div class="dashboard-action-row">
              <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-account-request-set="approved" data-request-id="${escapeHtml(requestId)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.accountApprove)}</span>
              </button>
              <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-account-request-set="rejected" data-request-id="${escapeHtml(requestId)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.accountReject)}</span>
              </button>
              <button type="button" class="ui-button ui-button-secondary ui-button-sm" data-dashboard-account-request-set="completed" data-request-id="${escapeHtml(requestId)}">
                <span class="ui-button-label">${escapeHtml(dashboardCopy.accountComplete)}</span>
              </button>
            </div>
          `;
          fragment.appendChild(row);
        });

        host.appendChild(fragment);
      };

      const renderLocaleProgressRows = (rows) => {
        const host = toNode(localeListNode);
        if (!host) return;

        host.innerHTML = '';

        const sourceList = Array.isArray(rows) ? rows : [];
        const candidates = sourceList
          .map((item) => {
            const localeCode = normalizeLanguage(item?.ui_locale || '').toUpperCase() || '-';
            const missing = normalizeCount(item?.missing_keys, 0);
            const untranslated = normalizeCount(item?.untranslated_keys, 0);
            const deployRequired = Boolean(item?.deploy_required);
            const coverageRaw = Number(item?.coverage_percent);
            const coverage = Number.isFinite(coverageRaw)
              ? Math.round(coverageRaw * 100) / 100
              : 0;

            return {
              localeCode,
              missing,
              untranslated,
              deployRequired,
              coverage,
            };
          })
          .filter((item) => item.missing > 0 || item.untranslated > 0 || item.deployRequired)
          .sort((left, right) => {
            if (right.missing !== left.missing) return right.missing - left.missing;
            if (right.untranslated !== left.untranslated) return right.untranslated - left.untranslated;
            if (Number(right.deployRequired) !== Number(left.deployRequired)) {
              return Number(right.deployRequired) - Number(left.deployRequired);
            }
            if (left.coverage !== right.coverage) return left.coverage - right.coverage;
            return left.localeCode.localeCompare(right.localeCode);
          })
          .slice(0, 6);

        if (!candidates.length) {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item';
          row.innerHTML = `<span>${escapeHtml(dashboardCopy.localeListEmpty)}</span>`;
          host.appendChild(row);
          return;
        }

        const fragment = document.createDocumentFragment();
        candidates.forEach((item) => {
          const row = document.createElement('li');
          row.className = 'dashboard-mini-item';
          const previewState = item.missing > 0
            ? 'missing'
            : item.untranslated > 0
              ? 'untranslated'
              : 'all';
          const localeHref = `${accountLocaleBasePath}?locale=${encodeURIComponent(item.localeCode.toLowerCase())}&state=${encodeURIComponent(previewState)}#locale-progress`;

          const detailParts = [];
          if (item.missing > 0) {
            detailParts.push(`${item.missing} ${dashboardCopy.localeListMissingLabel}`);
          }
          if (item.untranslated > 0) {
            detailParts.push(`${item.untranslated} ${dashboardCopy.localeListUntranslatedLabel}`);
          }
          if (item.deployRequired) {
            detailParts.push(dashboardCopy.localeListDeployLabel);
          }
          if (!detailParts.length) {
            detailParts.push(dashboardCopy.activityAllClear);
          }

          row.innerHTML = `
            <strong><a href="${escapeHtml(localeHref)}" data-dashboard-locale-link>${escapeHtml(item.localeCode)} · ${escapeHtml(`${item.coverage}%`)}</a></strong>
            <span>${escapeHtml(detailParts.join(' · '))}</span>
          `;
          fragment.appendChild(row);
        });

        host.appendChild(fragment);
      };

      const runModerationAction = async (session, commentId, status) => {
        if (!session?.jwt || !commentId || !status) return false;

        let moderationNotes = '';
        if (status === 'rejected' || status === 'spam') {
          moderationNotes = String(window.prompt(dashboardCopy.moderationNotesPrompt, '') || '').trim();
          if (!moderationNotes) {
            setFeedback(dashboardCopy.moderationNotesRequired, true);
            return false;
          }
        }

        const response = await fetch(`${authBaseUrl}/api/blog-comments/moderation/set`, {
          method: 'POST',
          headers: {
            Accept: 'application/json',
            'Content-Type': 'application/json',
            Authorization: `Bearer ${session.jwt}`,
          },
          body: JSON.stringify({
