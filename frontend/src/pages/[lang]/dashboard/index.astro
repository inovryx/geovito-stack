      const normalizeCount = (value, fallback = 0) => {
        const parsed = Number(value);
        if (!Number.isFinite(parsed) || parsed < 0) return fallback;
        return Math.round(parsed);
      };

      const normalizeOnboardingProgressData = (value) => {
        const source = value && typeof value === 'object' ? value : {};
        const normalized = {
          profile_completed: source.profile_completed === true,
          first_place_selected: source.first_place_selected === true,
          first_post_started: source.first_post_started === true,
          share_prompt_seen: source.share_prompt_seen === true,
          skipped: source.skipped === true,
        };
        const completedSteps = [
          normalized.profile_completed,
          normalized.first_place_selected,
          normalized.first_post_started,
          normalized.share_prompt_seen,
        ].filter(Boolean).length;
        const totalSteps = 4;
        const progressPercent = Math.round((completedSteps / totalSteps) * 100);
        const normalizedStatus = String(source.status || '')
          .trim()
          .toLowerCase();
        const status =
          normalizedStatus === 'completed' || normalizedStatus === 'skipped' || normalizedStatus === 'in_progress'
            ? normalizedStatus
            : normalized.skipped
              ? 'skipped'
              : completedSteps >= totalSteps
                ? 'completed'
                : 'in_progress';

        return {
          ...normalized,
          completed_steps: completedSteps,
          total_steps: totalSteps,
          progress_percent: Number.isFinite(Number(source.progress_percent))
            ? Math.max(0, Math.min(100, Math.round(Number(source.progress_percent))))
            : progressPercent,
          status,
        };
      };

