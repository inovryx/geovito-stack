            try {
              const ok = await runAccountRequestAction(currentSession, requestId, nextStatus);
              if (ok) {
                await loadDashboard(currentSession);
              }
            } finally {
              button.disabled = false;
            }
          });
        }

        if (savedListsItemsNode instanceof HTMLElement) {
          savedListsItemsNode.addEventListener('click', async (event) => {
            const target = event.target;
            const button =
              target instanceof HTMLElement ? target.closest('[data-dashboard-saved-remove]') : null;
            if (!(button instanceof HTMLButtonElement)) return;
            if (!currentSession || savedListsMutating) return;

            const listId = String(button.dataset.listId || '').trim();
            const targetType = String(button.dataset.targetType || '').trim().toLowerCase();
            const targetRef = String(button.dataset.targetRef || '').trim();
            if (!listId || !targetType || !targetRef) return;

            const label = button.querySelector('.ui-button-label');
            button.disabled = true;
            if (label) label.textContent = dashboardCopy.savedListsRemovingItem;
            savedListsMutating = true;
            setFeedback(dashboardCopy.savedListsRemovingItem);

            try {
              const ok = await runSavedItemRemoveAction(currentSession, listId, targetType, targetRef);
              if (ok) {
                await loadDashboard(currentSession);
                setFeedback(dashboardCopy.savedListsItemRemoved);
              }
            } finally {
              savedListsMutating = false;
              if (button.isConnected) {
                button.disabled = false;
                if (label) label.textContent = dashboardCopy.savedListsRemoveItem;
              }
            }
          });
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true });
      } else {
        void init();
      }
    })();
  </script>
</MainLayout>

