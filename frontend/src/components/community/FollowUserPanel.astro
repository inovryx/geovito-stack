---
import { resolveStrapiBaseUrl } from '../../lib/strapiConfig';
import { getUiMessages, resolvePreferredLanguage, translate } from '../../lib/uiLanguage';

interface Props {
  username: string;
  lang?: string;
}

const { username: rawUsername, lang: rawLang = 'en' } = Astro.props as Props;
const username = String(rawUsername || '').trim().toLowerCase();
const lang = resolvePreferredLanguage([rawLang, 'en']);
const loginPath = `/${lang}/login/`;
const ui = getUiMessages(lang);

const authBaseUrl = resolveStrapiBaseUrl({
  STRAPI_URL: import.meta.env.STRAPI_URL as string | undefined,
  PUBLIC_STRAPI_URL: import.meta.env.PUBLIC_STRAPI_URL as string | undefined,
  CF_PAGES: process.env.CF_PAGES,
  NODE_ENV: process.env.NODE_ENV,
  ALLOW_LOCALHOST_STRAPI:
    process.env.ALLOW_LOCALHOST_STRAPI || (import.meta.env.ALLOW_LOCALHOST_STRAPI as string | undefined),
});

const t = (key: string, params: Record<string, string | number> = {}, fallback?: string) =>
  translate(ui, key, params, fallback);

const panelTitle = t('profile.followPanel.title', {}, 'Follow creator');
const panelSubtitle = t(
  'profile.followPanel.subtitle',
  { username: `@${username}` },
  'Follow {username} to keep this creator in your personal feed.'
);
const followLabel = t('profile.followPanel.followLabel', {}, 'Follow');
const followingLabel = t('profile.followPanel.followingLabel', {}, 'Following');
const loginLabel = t('profile.followPanel.loginLabel', {}, 'Login');
const loginRequired = t('profile.followPanel.loginRequired', {}, 'Login required to follow creators.');
const ownProfile = t('profile.followPanel.ownProfile', {}, 'This is your profile.');
const loadingState = t('profile.followPanel.loadingState', {}, 'Loading follow state...');
const sessionExpired = t('profile.followPanel.sessionExpired', {}, 'Session expired. Please login again.');
const loadFailed = t('profile.followPanel.loadFailed', {}, 'Could not load follow state.');
const systemDisabled = t('profile.followPanel.systemDisabled', {}, 'Follow system is currently disabled.');
const loadNetworkError = t('profile.followPanel.loadNetworkError', {}, 'Network error while loading follow state.');
const updatingState = t('profile.followPanel.updatingState', {}, 'Updating follow status...');
const updateFailed = t('profile.followPanel.updateFailed', {}, 'Could not update follow status.');
const updateNetworkError = t('profile.followPanel.updateNetworkError', {}, 'Network error while updating follow status.');
const followSuccess = t('profile.followPanel.followSuccess', { username: `@${username}` }, 'You are now following {username}.');
const unfollowSuccess = t('profile.followPanel.unfollowSuccess', { username: `@${username}` }, 'Unfollowed {username}.');
---

<section class="card panel gv-card gv-stack follow-user-panel" data-follow-user-panel data-auth-base={authBaseUrl}>
  <h2 class="gv-h2">{panelTitle}</h2>
  <p class="small" data-follow-user-subtitle>{panelSubtitle}</p>
  <div class="gv-row gv-row--gap gv-row--wrap" data-follow-user-controls>
    <button type="button" class="ui-button ui-button-primary ui-button-md" data-follow-user-toggle>
      <span class="ui-button-label">{followLabel}</span>
    </button>
    <a class="ui-button ui-button-secondary ui-button-sm" href={loginPath} data-follow-user-login hidden>{loginLabel}</a>
  </div>
  <p class="small account-feedback" data-follow-user-feedback aria-live="polite"></p>
</section>

<script
  is:inline
  define:vars={{
    username,
    authBaseUrl,
    loginPath,
    followLabel,
    followingLabel,
    loginRequired,
    ownProfile,
    loadingState,
    sessionExpired,
    loadFailed,
    systemDisabled,
    loadNetworkError,
    updatingState,
    updateFailed,
    updateNetworkError,
    followSuccess,
    unfollowSuccess,
  }}
>
  (() => {
    const root = document.querySelector('[data-follow-user-panel]');
    if (!(root instanceof HTMLElement)) return;

    const toggleButton = root.querySelector('[data-follow-user-toggle]');
    const loginButton = root.querySelector('[data-follow-user-login]');
    const subtitle = root.querySelector('[data-follow-user-subtitle]');
    const feedback = root.querySelector('[data-follow-user-feedback]');
    if (
      !(toggleButton instanceof HTMLButtonElement) ||
      !(loginButton instanceof HTMLAnchorElement) ||
      !(subtitle instanceof HTMLElement) ||
      !(feedback instanceof HTMLElement)
    ) {
      return;
    }

    const targetUsername = String(username || '').trim().toLowerCase();
    if (!targetUsername) return;

    const readSession = () => {
      try {
        const fromLocal = localStorage.getItem('geovito_auth_session');
        if (fromLocal) return JSON.parse(fromLocal);
        const fromSession = sessionStorage.getItem('geovito_auth_session');
        if (fromSession) {
          localStorage.setItem('geovito_auth_session', fromSession);
          return JSON.parse(fromSession);
        }
      } catch (_error) {
        return null;
      }
      return null;
    };

    const setFeedback = (message, isError = false) => {
      feedback.textContent = String(message || '');
      feedback.classList.toggle('is-error', Boolean(isError));
    };

    const setButtonState = (following) => {
      const label = toggleButton.querySelector('.ui-button-label');
      const isFollowing = following === true;
      toggleButton.dataset.following = isFollowing ? 'true' : 'false';
      toggleButton.classList.toggle('ui-button-secondary', isFollowing);
      toggleButton.classList.toggle('ui-button-primary', !isFollowing);
      if (label) {
        label.textContent = isFollowing ? followingLabel : followLabel;
      }
    };

    const fetchMyFollows = async (jwt) => {
      const response = await fetch(`${authBaseUrl}/api/user-follows/me/list?target_type=user&limit=500`, {
        headers: {
          Accept: 'application/json',
          Authorization: `Bearer ${jwt}`,
        },
      });
      const payload = await response.json().catch(() => ({}));
      return {
        ok: response.ok,
        status: response.status,
        payload,
      };
    };

    const session = readSession();
    const jwt = typeof session?.jwt === 'string' ? session.jwt : '';
    if (!jwt) {
      toggleButton.hidden = true;
      loginButton.hidden = false;
      loginButton.href = loginPath;
      setFeedback(loginRequired);
      return;
    }

    const authUsername = String(session?.user?.username || '').trim().toLowerCase();
    if (authUsername && authUsername === targetUsername) {
      toggleButton.hidden = true;
      loginButton.hidden = true;
      subtitle.textContent = ownProfile;
      setFeedback('');
      return;
    }

    let followEnabled = true;

    const refreshState = async () => {
      setFeedback(loadingState);
      try {
        const result = await fetchMyFollows(jwt);
        if (!result.ok) {
          if (result.status === 401) {
            toggleButton.hidden = true;
            loginButton.hidden = false;
            loginButton.href = loginPath;
            setFeedback(sessionExpired, true);
            return;
          }
          setFeedback(loadFailed, true);
          return;
        }

        const data = result.payload?.data && typeof result.payload.data === 'object' ? result.payload.data : {};
        const items = Array.isArray(data.items) ? data.items : [];
        followEnabled = data.follow_system_enabled === true;
        if (!followEnabled) {
          toggleButton.disabled = true;
          setButtonState(false);
          setFeedback(systemDisabled);
          return;
        }

        const following = items.some((row) => String(row?.target_ref || '').trim().toLowerCase() === targetUsername);
        setButtonState(following);
        toggleButton.disabled = false;
        setFeedback('');
      } catch (_error) {
        setFeedback(loadNetworkError, true);
      }
    };

    toggleButton.addEventListener('click', async () => {
      if (!followEnabled) {
        setFeedback(systemDisabled);
        return;
      }

      toggleButton.disabled = true;
      setFeedback(updatingState);
      try {
        const response = await fetch(`${authBaseUrl}/api/user-follows/me/toggle`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
            Authorization: `Bearer ${jwt}`,
          },
          body: JSON.stringify({
            target_type: 'user',
            target_ref: targetUsername,
          }),
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          const message = payload?.error?.message || updateFailed;
          setFeedback(message, true);
          toggleButton.disabled = false;
          return;
        }

        const following = payload?.data?.following === true;
        setButtonState(following);
        setFeedback(following ? followSuccess : unfollowSuccess);
      } catch (_error) {
        setFeedback(updateNetworkError, true);
      } finally {
        toggleButton.disabled = false;
      }
    });

    refreshState();
  })();
</script>
