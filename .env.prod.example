## Geovito PROD-FIRST environment template
## This stack is production-safe by default.
## Mock data is manual + guarded.
## AI provider hookup is out of scope for this phase.

NODE_ENV=production
# Keep HOST=0.0.0.0 for in-network container access.
# External exposure stays private via docker-compose port bind: 127.0.0.1:1337.
HOST=0.0.0.0
PORT=1337
SERVER_URL=https://cms.geovito.com
IS_PROXIED=true
LOG_LEVEL=info
HEALTH_TOKEN=

# Frontend/Pages build env mapping
STRAPI_URL=https://cms.geovito.com
PUBLIC_SITE_URL=https://www.geovito.com
PUBLIC_SITE_LOCKDOWN_ENABLED=false
PUBLIC_SITE_LOCKDOWN_NOTICE=Test mode is active. This environment is not open for public usage.
PUBLIC_AUTH_LOCAL_REGISTER_ENABLED=true
PUBLIC_AUTH_GOOGLE_ENABLED=false
PUBLIC_AUTH_FACEBOOK_ENABLED=false
PUBLIC_TURNSTILE_SITE_KEY=
# Optional (only if STRAPI_URL is behind Cloudflare Access):
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

SEED_ON_BOOT=false
SEED_MOCK_ON_BOOT=false
ALLOW_MOCK_SEED=false
AUTH_LOCAL_REGISTER_ENABLED=true
AUTH_GOOGLE_ENABLED=false
AUTH_FACEBOOK_ENABLED=false
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_CALLBACK_PATH=api/connect/google/callback
AUTH_GOOGLE_SCOPE=email
AUTH_FACEBOOK_CLIENT_ID=
AUTH_FACEBOOK_CLIENT_SECRET=
AUTH_FACEBOOK_CALLBACK_PATH=api/connect/facebook/callback
AUTH_FACEBOOK_SCOPE=email
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
BLOG_COMMENT_REGISTERED_AUTO_APPROVE_AFTER=2
BLOG_COMMENT_GUEST_TURNSTILE_REQUIRED=false
BLOG_COMMENT_GUEST_MAX_LINKS=1
BLOG_COMMENT_GUEST_SPAM_LINKS=3
BLOG_COMMENT_IP_HASH_SALT=
BLOG_LIKE_IP_HASH_SALT=
BLOG_LIKE_RATE_WINDOW_MS=60000
BLOG_LIKE_RATE_MAX=60
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
EMAIL_PROVIDER=sendmail
EMAIL_DEFAULT_FROM=noreply@geovito.com
EMAIL_DEFAULT_REPLY_TO=support@geovito.com
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_IGNORE_TLS=false
EMAIL_SMTP_REQUIRE_TLS=true
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_POOL=true
EMAIL_SMTP_MAX_CONNECTIONS=5
EMAIL_SMTP_MAX_MESSAGES=100
EMAIL_SMTP_REJECT_UNAUTHORIZED=true
EMAIL_SMOKE_TO=
UPLOAD_MAX_FILE_SIZE_BYTES=8388608
UPLOAD_BREAKPOINT_LARGE=1280
UPLOAD_BREAKPOINT_MEDIUM=768
UPLOAD_BREAKPOINT_SMALL=480
MEDIA_IMAGE_CONVERT_ENABLED=true
# webp-first policy: keep target webp in baseline
MEDIA_IMAGE_TARGET_FORMAT=webp
MEDIA_IMAGE_ALLOWED_INPUT_MIME=jpg,jpeg,png,webp
MEDIA_IMAGE_QUALITY=82
MEDIA_IMAGE_MAX_INPUT_BYTES=20971520
MEDIA_IMAGE_CONVERT_STRICT=false
IMPORT_ENABLED=false
TRANSLATION_BUNDLE_ENABLED=false
TRANSLATION_BUNDLE_ALLOW_STATUS_PROMOTE=false

DATABASE_CLIENT=postgres
DATABASE_SCHEMA=public
DATABASE_SSL=false
POSTGRES_DB=geovito
POSTGRES_USER=geovito
DB_PASS=replace_with_strong_password

APP_KEYS=replace_with_4_comma_separated_values
API_TOKEN_SALT=replace_with_strong_random_value
ADMIN_JWT_SECRET=replace_with_strong_random_value
TRANSFER_TOKEN_SALT=replace_with_strong_random_value
JWT_SECRET=replace_with_strong_random_value
ENCRYPTION_KEY=replace_with_strong_random_value

SEARCH_WEBHOOK_SECRET=replace_with_strong_random_value
SEARCH_REINDEX_TOKEN=replace_with_strong_random_value

AI_ENABLED=false
AI_DIAGNOSTICS_ENABLED=false
AI_DRAFT_ENABLED=false
AI_AUTHOR_LANGUAGES=en,tr,de,es,ru,zh-cn
