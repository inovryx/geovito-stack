# Launch Kit local development profile template (generic-first)
# Template-only file. Real secrets must stay in host-local files (not in git).

PROJECT_SLUG=geovito
PROJECT_SITE_NAME=Geovito
PROJECT_TYPE=travel-community

LOCAL_APP_BASE_URL=http://127.0.0.1:4321
LOCAL_CMS_BASE_URL=http://127.0.0.1:1337
LOCAL_CANONICAL_LOCALE=en

# Allowed: console|mailsink|sendmail|nodemailer
LOCAL_SMTP_MODE=console

# Allowed: local|r2|s3|gcs|mixed
LOCAL_STORAGE_MODE=local

LOCAL_DEBUG=true
LOCAL_ANALYTICS_ENABLED=false
LOCAL_ANALYTICS_PROVIDER=none

# Host-local secret file suggestion (not committed)
LOCAL_SECRET_FILE=~/.config/geovito/local.secrets.env

# Secret placeholders (must stay placeholder in repo)
LOCAL_DB_PASSWORD=REPLACE_WITH_SECRET
LOCAL_API_TOKEN=REPLACE_WITH_SECRET
