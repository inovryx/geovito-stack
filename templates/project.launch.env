# Launch Kit deployment profile template (generic-first)
# Template-only file. Do not commit real secrets.

PROJECT_SLUG=geovito
PROJECT_SITE_NAME=Geovito
PROJECT_TYPE=travel-community
LAUNCH_CANONICAL_LOCALE=en

# Domain profile (hostnames only, no scheme)
LAUNCH_PROD_APP_DOMAIN=www.geovito.com
LAUNCH_PROD_CMS_DOMAIN=cms.geovito.com
LAUNCH_STAGING_APP_DOMAIN=staging.geovito.com
LAUNCH_STAGING_CMS_DOMAIN=cms-staging.geovito.com
LAUNCH_OPTIONAL_WWW_DOMAIN=

# Cloudflare profile
LAUNCH_CLOUDFLARE_ZONE_NAME=geovito.com
LAUNCH_CLOUDFLARE_ZONE_ID=REPLACE_WITH_CF_ZONE_ID
LAUNCH_CLOUDFLARE_ACCOUNT_ID=REPLACE_WITH_CF_ACCOUNT_ID

# Allowed: sendmail|nodemailer|mailsink
LAUNCH_SMTP_MODE=nodemailer
LAUNCH_SMTP_BLOCK_REAL=true

# Storage profile
# Allowed: local|r2|s3|gcs|mixed
LAUNCH_STORAGE_PRIMARY=r2
LAUNCH_STORAGE_BACKUP=local
LAUNCH_STORAGE_BUCKET=geovito-backups
LAUNCH_STORAGE_PREFIX=geovito-prod

# Analytics placeholders
LAUNCH_ANALYTICS_PROVIDER=none
LAUNCH_ANALYTICS_GA4_ID=REPLACE_WITH_GA4_ID
LAUNCH_ANALYTICS_GTM_ID=REPLACE_WITH_GTM_ID

# Secret placeholders (must stay placeholder in repo)
LAUNCH_CLOUDFLARE_API_TOKEN=REPLACE_WITH_SECRET
LAUNCH_SMTP_USER=REPLACE_WITH_SECRET
LAUNCH_SMTP_PASS=REPLACE_WITH_SECRET
LAUNCH_SENTRY_DSN=REPLACE_WITH_SECRET
