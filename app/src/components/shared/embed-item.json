{
  "collectionName": "components_shared_embed_items",
  "info": {
    "displayName": "Embed Item",
    "icon": "play",
    "description": "Provider-whitelisted video embed entry"
  },
  "options": {},
  "attributes": {
    "provider": {
      "type": "enumeration",
      "enum": ["youtube", "facebook"],
      "required": true
    },
    "source_url": {
      "type": "string",
      "required": true,
      "maxLength": 1000
    },
    "title": {
      "type": "string",
      "maxLength": 140
    },
    "caption": {
      "type": "text",
      "maxLength": 280
    },
    "start_seconds": {
      "type": "integer",
      "min": 0,
      "max": 86400
    }
  }
}

