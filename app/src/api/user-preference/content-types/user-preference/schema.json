{
  "kind": "collectionType",
  "collectionName": "user_preferences",
  "info": {
    "singularName": "user-preference",
    "pluralName": "user-preferences",
    "displayName": "User Preference",
    "description": "Per-user UI and notification preferences"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "owner_user_id": {
      "type": "integer",
      "required": true,
      "unique": true
    },
    "preferred_ui_language": {
      "type": "string",
      "required": true,
      "default": "en"
    },
    "notifications_site_enabled": {
      "type": "boolean",
      "default": true
    },
    "notifications_email_enabled": {
      "type": "boolean",
      "default": true
    },
    "notifications_digest": {
      "type": "enumeration",
      "enum": ["off", "instant", "daily", "weekly"],
      "default": "daily"
    },
    "onboarding_progress": {
      "type": "json"
    },
    "updated_from_ip": {
      "type": "string"
    },
    "notes": {
      "type": "text"
    }
  }
}
